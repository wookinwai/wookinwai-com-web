# Expose Astro dependencies for `pnpm` users
shamefully-hoist=true

# @jdevalk/astro-seo-graph@2.0.0 declares peerDependencies astro@^6.0.0; its
# latest published version hasn't bumped that range for Astro 7 yet, even
# though it works correctly in practice (verified across many builds on
# astro@7.0.2). Remove this once an upstream release widens the peer range.
legacy-peer-deps=true