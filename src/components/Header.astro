---
// A title page, not chrome: monogram + wordmark left, contents + theme right.
// Deliberately not sticky — the book doesn't follow you down the page.
import { NAV } from '../consts';
import Monogram from './Monogram.astro';

const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  !href.includes('#') && href !== '/' && (path === href || path.startsWith(href + '/'));
---

<header class="pt-11">
  <div class="mx-auto flex max-w-[1060px] items-center justify-between gap-[18px] px-7">
    <a href="/" class="flex items-center gap-3.5 no-underline hover:text-ink">
      <Monogram />
      <span class="font-serif text-[21px] font-medium tracking-[0.01em]">
        Woo Kin&nbsp;Wai<i class="italic text-ribbon">,</i> Tiny Edges
      </span>
    </a>
    <nav class="flex items-center gap-[26px] max-[820px]:hidden" aria-label="Contents">
      {
        NAV.map((link) => (
          <a
            href={link.href}
            aria-current={isCurrent(link.href) ? 'page' : undefined}
            class:list={[
              'font-sans text-[13px] font-medium no-underline hover:text-ribbon',
              isCurrent(link.href) ? 'text-ribbon' : 'text-soft',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <button
        id="theme"
        class="cursor-pointer rounded-full border border-hairline bg-transparent px-3.5 py-1.5 font-sans text-[12.5px] text-soft transition-colors hover:border-ribbon hover:text-ribbon"
      >
        <span class="lamp-label">Lamplight</span><span class="day-label">Daylight</span>
      </button>
    </nav>
  </div>
</header>

<style>
  .day-label {
    display: none;
  }
  :global(html[data-pal='lamp']) .lamp-label {
    display: none;
  }
  :global(html[data-pal='lamp']) .day-label {
    display: inline;
  }
</style>
