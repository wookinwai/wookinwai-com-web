---
// The email CTA, Quiet Pages style: not a button at all — an italic line of
// the address, underlined in ribbon green, the way a book sets a reply card.
import { SITE } from '../consts';

export interface Props {
  size?: 'lg' | 'md';
  class?: string;
}
const { size = 'lg', class: extra = '' } = Astro.props;
const sizeCls = size === 'lg' ? 'text-[21px]' : 'text-[18px]';
---

<a
  href={`mailto:${SITE.email}`}
  class:list={[
    'inline-block font-serif italic underline decoration-ribbon decoration-1 underline-offset-[5px]',
    sizeCls,
    extra,
  ]}
>
  {SITE.email}
</a>
