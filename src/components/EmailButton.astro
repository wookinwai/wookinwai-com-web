---
import { SITE } from '../consts';

// The drafting-table email CTA — mono, drafting green, a single rule
// underneath, like a contact line in a title block. `lg` is the display size;
// `md` is a tighter pull.
export interface Props {
  size?: 'lg' | 'md';
  class?: string;
}
const { size = 'lg', class: extra = '' } = Astro.props;

const sizeCls = size === 'lg' ? 'text-[clamp(18px,2.6vw,24px)]' : 'text-[clamp(15px,2vw,18px)]';
---

<a
  href={`mailto:${SITE.email}`}
  class:list={[
    'inline-block border-b-[1.5px] border-acc pb-0.5 font-mono text-acc no-underline transition-colors hover:border-acc-2 hover:text-acc-2',
    sizeCls,
    extra,
  ]}
>
  {SITE.email}
</a>
