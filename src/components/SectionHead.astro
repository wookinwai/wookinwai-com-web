---
// Press Mono section masthead — stacked broadsheet composition:
//   • red mono kicker (index) tight above the headline (they belong together)
//   • heavy sentence-case headline, full body width
//   • the dek (sub) sits BELOW the headline as a caption — top-and-bottom, not
//     left-and-right — so the whole cluster reads as one full-width band
//   • one hard 3px ink rule under the whole cluster (draws in on scroll reveal)
export interface Props {
  index: string;
  title: string;
  sub?: string;
}
const { index, title, sub } = Astro.props;
---

<div class="relative pb-[18px]">
  <div class="mb-[14px] font-mono text-[11px] font-bold uppercase tracking-[0.22em] text-acc">{index}</div>
  <h2 class="m-0 font-sans text-[clamp(30px,4.4vw,52px)] font-extrabold leading-[1.02] tracking-[-0.03em] text-ink">
    {title}
  </h2>
  {
    sub && (
      <p class="mt-[18px] w-full font-mono text-[12px] leading-[1.55] text-mut">
        {sub}
      </p>
    )
  }
  <div class="sec-rule absolute inset-x-0 bottom-0 h-[3px] bg-rule"></div>
</div>
