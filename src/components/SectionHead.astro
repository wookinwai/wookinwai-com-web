---
// Press Mono section masthead — left-label-rail editorial grid:
//   • a narrow LEFT rail holds the red mono kicker (index) + the dek (sub) as
//     marginalia (and, via the `rail` slot, extra margin content e.g. a portrait)
//   • the MAIN column holds the heavy sentence-case headline, the hard 3px rule
//     (draws in on scroll reveal), and the section body (default slot)
//   • everything in the main column shares one comfortable measure; the rail is
//     intentional labeled whitespace. Collapses to a single stacked column < 760px.
export interface Props {
  index: string;
  title: string;
  sub?: string;
}
const { index, title, sub } = Astro.props;
---

<div class="sec-grid">
  <div class="sec-rail">
    <div class="sec-kicker">{index}</div>
    {sub && <p class="sec-dek">{sub}</p>}
    <slot name="rail" />
  </div>
  <div class="sec-main">
    <h2 class="sec-title">{title}</h2>
    <div class="sec-rule"></div>
    <slot />
  </div>
</div>
