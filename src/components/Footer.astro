---
import { SITE, SOCIALS } from '../consts';

const year = new Date().getFullYear();
const linkClass = 'text-soft no-underline transition-colors hover:text-acc';
const dot = 'text-line';
---

<footer
  class="mt-24 flex flex-wrap items-center justify-between gap-x-6 gap-y-3 border-t-[3px] border-rule pb-20 pt-[26px] font-mono text-[11px] font-medium uppercase tracking-[0.04em] text-soft"
>
  <span>
    © {year} <b class="font-bold text-ink">{SITE.author}</b> ·
    <a href={SITE.orgUrl} target="_blank" rel="noopener noreferrer" class={linkClass}>{SITE.org}</a>
  </span>

  <span class="flex flex-wrap items-center gap-x-3 gap-y-1">
    {
      SOCIALS.map((s) => (
        <>
          <a href={s.href} target="_blank" rel="noopener noreferrer" class={linkClass}>
            {s.label} ↗
          </a>
          <span aria-hidden="true" class={dot}>·</span>
        </>
      ))
    }
    <a href="#top" class={linkClass}>↑ Back to top</a>
  </span>
</footer>
