---
import { SITE, SOCIALS } from '../consts';

const year = new Date().getFullYear();
---

<footer class="mt-[90px] border-t border-hairline pb-14 pt-[26px]">
  <div class="mx-auto flex max-w-[1060px] flex-wrap justify-between gap-3.5 px-7">
    <span class="caption">
      © {year}
      {SITE.author} ·
      <a href={SITE.orgUrl} target="_blank" rel="noopener noreferrer" class="no-underline hover:underline">{SITE.org}</a
      >
      · {SITE.location}
    </span>
    <span class="caption">
      {
        SOCIALS.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="no-underline hover:underline">
            {s.label}
          </a>
        ))
      }
      &nbsp;·&nbsp;
      <a href="#top" class="no-underline hover:underline">Back to the top</a>
    </span>
  </div>
</footer>
