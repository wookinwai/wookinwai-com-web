---
import type { IconName } from '../consts';

// Inline-SVG icon set for the digital business card. No icon library — same
// "hand-rolled SVG that inherits currentColor" convention as the footer chip.
// Each path is authored on a 24×24 grid; the wrapper sets a 15px default so it
// rhymes with the LinkedIn mark in Footer.astro.
export interface Props {
  name: IconName;
  class?: string;
}
const { name, class: extra = '' } = Astro.props;

const paths: Record<IconName, string> = {
  // LinkedIn "in" mark — shared with Footer.astro
  linkedin:
    'M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.3c0-1.26-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21h-4z',
  // X (formerly Twitter) glyph
  x: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  // Facebook "f"
  facebook:
    'M13.5 21v-8.4h2.82l.42-3.28H13.5V7.22c0-.95.26-1.6 1.63-1.6h1.74V2.69A23.3 23.3 0 0 0 14.33 2.5c-2.51 0-4.23 1.53-4.23 4.35v2.47H7.27v3.28H10.1V21z',
  // Instagram (rounded-square camera, drawn with strokes + a dot)
  instagram:
    'M7.5 2.5h9A5 5 0 0 1 21.5 7.5v9a5 5 0 0 1-5 5h-9a5 5 0 0 1-5-5v-9a5 5 0 0 1 5-5zm0 2A3 3 0 0 0 4.5 7.5v9a3 3 0 0 0 3 3h9a3 3 0 0 0 3-3v-9a3 3 0 0 0-3-3zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm5.25-2.75a1 1 0 1 1 0 2 1 1 0 0 1 0-2z',
  // Email — closed envelope
  email:
    'M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm1.4 2L12 12.1 19.6 7H4.4zM20 8.32l-7.43 4.96a1 1 0 0 1-1.14 0L4 8.32V17h16z',
  // Work / external — globe
  work: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm6.93 6h-3.02a14.7 14.7 0 0 0-1.27-3.49A8.03 8.03 0 0 1 18.93 8zM12 4.04c.74 1.07 1.32 2.36 1.7 3.96h-3.4c.38-1.6.96-2.89 1.7-3.96zM4.26 14a7.96 7.96 0 0 1 0-4h3.38a16.5 16.5 0 0 0 0 4zm.81 2h3.02c.32 1.27.75 2.45 1.27 3.49A8.03 8.03 0 0 1 5.07 16zm3.02-8H5.07a8.03 8.03 0 0 1 4.29-3.49A14.7 14.7 0 0 0 8.09 8zM12 19.96c-.74-1.07-1.32-2.36-1.7-3.96h3.4c-.38 1.6-.96 2.89-1.7 3.96zM9.83 14a14.6 14.6 0 0 1 0-4h4.34a14.6 14.6 0 0 1 0 4zm4.84 5.49c.52-1.04.95-2.22 1.27-3.49h3.02a8.03 8.03 0 0 1-4.29 3.49zM16.36 14a16.5 16.5 0 0 0 0-4h3.38a7.96 7.96 0 0 1 0 4z',
};
---

<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true" class:list={[extra]}>
  <path d={paths[name]}></path>
</svg>
