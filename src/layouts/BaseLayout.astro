---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PlotBackground from '../components/PlotBackground.astro';

// Self-hosted fonts (Fontsource). The Drafting Table speaks in Source Serif 4
// (voice + display) and IBM Plex Mono (annotations, labels, figure numbers).
// The opsz variants carry the [opsz,wght] axes, so large headings render in
// the sharp display optical size — same cut as Google Fonts serves.
import '@fontsource-variable/source-serif-4/opsz.css';
import '@fontsource-variable/source-serif-4/opsz-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';

// Preload the above-the-fold body/display face.
import serifWoff2 from '@fontsource-variable/source-serif-4/files/source-serif-4-latin-opsz-normal.woff2?url';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
}

const { title, description, canonical, image } = Astro.props;
---

<!doctype html>
<html lang="en" data-pal="paper">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Set the palette + motion flag before first paint to avoid a flash.
         `.motion` gates the staggered-reveal hidden states in CSS, so anything
         that starts hidden only does so when JS is on AND motion is welcome. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('pal');
          var pal =
            stored === 'ink' || stored === 'paper'
              ? stored
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'ink'
                : 'paper';
          document.documentElement.dataset.pal = pal;
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('motion');
          }
        } catch (e) {}
      })();
    </script>

    <link rel="preload" as="font" type="font/woff2" href={serifWoff2} crossorigin />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Woo Kin Wai" href="/rss.xml" />
    <meta name="theme-color" content="#f4f0e2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#201c13" media="(prefers-color-scheme: dark)" />

    <SEO title={title} description={description} canonical={canonical} image={image} />

    <ClientRouter />
  </head>

  <body id="top" class="relative overflow-x-hidden bg-bg font-sans text-[17px] leading-[1.55] text-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:border focus:border-rule focus:bg-panel focus:px-4 focus:py-2 focus:font-mono focus:text-[12px] focus:text-ink focus:no-underline"
      >Skip to content</a
    >

    <PlotBackground />

    <Header transition:persist />

    <div class="relative z-[2] mx-auto max-w-[1180px] px-14 max-[900px]:px-7 max-[560px]:px-5">
      <main id="main"><slot /></main>
    </div>

    <Footer />

    <script>
      import { animate, stagger } from 'animejs';

      // Re-assert the chosen palette + motion flag after each View-Transitions swap.
      // Astro copies the incoming page's hardcoded <html data-pal="paper"> onto the
      // live root, and the is:inline head script does NOT re-run on navigation — so
      // without this, lamplight (and the .motion gate) would reset on every page change.
      // astro:after-swap fires before paint, so there's no theme flash mid-transition.
      function applyChrome() {
        try {
          const stored = localStorage.getItem('pal');
          const pal =
            stored === 'ink' || stored === 'paper'
              ? stored
              : matchMedia('(prefers-color-scheme: dark)').matches
                ? 'ink'
                : 'paper';
          document.documentElement.dataset.pal = pal;
          if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('motion');
          }
        } catch (e) {}
      }
      document.addEventListener('astro:after-swap', applyChrome);

      // Re-runs on first load and after every client-side (View Transitions)
      // navigation, so handlers re-bind to fresh DOM.
      function init() {
        // Theme toggle — persists the chosen palette (paper ⇄ ink/lamplight).
        const btn = document.getElementById('theme');
        if (btn && !btn.dataset.bound) {
          btn.dataset.bound = 'true';
          btn.addEventListener('click', () => {
            const root = document.documentElement;
            const next = root.dataset.pal === 'ink' ? 'paper' : 'ink';
            root.dataset.pal = next;
            try {
              localStorage.setItem('pal', next);
            } catch (e) {}
          });
        }

        // Reveal sections on scroll (figure head fade + the section rule drawing in).
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

        // Staggered content reveals — the children of a [data-stagger] group
        // cascade in (rise + fade) as it scrolls into view. Drafted, restrained:
        // small offset, crisp out-cubic, tight stagger. Gated on `.motion` so
        // reduced-motion / no-JS keep everything visible (see global.css).
        if (document.documentElement.classList.contains('motion')) {
          const sio = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (!e.isIntersecting) return;
                const items = Array.from((e.target as HTMLElement).children) as HTMLElement[];
                animate(items, {
                  opacity: [0, 1],
                  translateY: [14, 0],
                  duration: 600,
                  delay: stagger(55),
                  ease: 'outCubic',
                  onComplete: () => items.forEach((el) => (el.style.willChange = 'auto')),
                });
                sio.unobserve(e.target);
              });
            },
            { threshold: 0.16, rootMargin: '0px 0px -6% 0px' }
          );
          document.querySelectorAll<HTMLElement>('[data-stagger]').forEach((el) => {
            if (el.dataset.staggerBound) return;
            el.dataset.staggerBound = 'true';
            sio.observe(el);
          });
        }
      }

      document.addEventListener('astro:page-load', init);
    </script>
  </body>
</html>
