---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Self-hosted fonts (Fontsource variable). Press Mono uses only Hanken Grotesk
// (voice + display) and JetBrains Mono (structural labels) — no serif.
import '@fontsource-variable/hanken-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

// Preload the above-the-fold body/display face.
import hankenWoff2 from '@fontsource-variable/hanken-grotesk/files/hanken-grotesk-latin-wght-normal.woff2?url';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
}

const { title, description, canonical, image } = Astro.props;
---

<!doctype html>
<html lang="en" data-pal="press">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Set the palette + motion flag before first paint to avoid a flash.
         `.motion` gates the staggered-reveal hidden states in CSS, so anything
         that starts hidden only does so when JS is on AND motion is welcome. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('pal');
          var pal = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'ink' : 'press');
          document.documentElement.dataset.pal = pal;
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('motion');
          }
        } catch (e) {}
      })();
    </script>

    <link rel="preload" as="font" type="font/woff2" href={hankenWoff2} crossorigin />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Woo Kin Wai" href="/rss.xml" />
    <meta name="theme-color" content="#f2eee4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#16140f" media="(prefers-color-scheme: dark)" />

    <SEO title={title} description={description} canonical={canonical} image={image} />

    <ClientRouter />
  </head>

  <body id="top" class="relative overflow-x-hidden bg-bg font-sans text-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:border-2 focus:border-rule focus:bg-panel focus:px-4 focus:py-2 focus:font-mono focus:text-[12px] focus:uppercase focus:tracking-[0.12em] focus:text-ink focus:no-underline"
      >Skip to content</a
    >

    <div class="grid-bg"></div>

    <Header transition:persist />

    <div class="relative z-[2] mx-auto max-w-[1040px] px-10 max-[760px]:px-[22px]">
      <main id="main"><slot /></main>
      <Footer />
    </div>

    <script>
      import { animate, stagger } from 'animejs';

      // Re-runs on first load and after every client-side (View Transitions)
      // navigation, so handlers re-bind to fresh DOM.
      function init() {
        // Theme toggle — persists the chosen palette (press ⇄ ink).
        const btn = document.getElementById('theme');
        if (btn && !btn.dataset.bound) {
          btn.dataset.bound = 'true';
          btn.addEventListener('click', () => {
            const root = document.documentElement;
            const next = root.dataset.pal === 'ink' ? 'press' : 'ink';
            root.dataset.pal = next;
            try {
              localStorage.setItem('pal', next);
            } catch (e) {}
          });
        }

        // Selected-work accordions: clicking the row toggles `.open` on the .flow.
        document.querySelectorAll<HTMLElement>('.flow-main').forEach((m) => {
          if (m.dataset.bound) return;
          m.dataset.bound = 'true';
          m.addEventListener('click', () => m.parentElement?.classList.toggle('open'));
        });

        // Reveal sections on scroll (masthead fade + the section rule drawing in).
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

        // Staggered content reveals — the children of a [data-stagger] group
        // cascade in (rise + fade) as it scrolls into view. Mechanical, restrained:
        // small offset, crisp out-cubic, tight stagger. Gated on `.motion` so
        // reduced-motion / no-JS keep everything visible (see global.css).
        if (document.documentElement.classList.contains('motion')) {
          const sio = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (!e.isIntersecting) return;
                const items = Array.from((e.target as HTMLElement).children) as HTMLElement[];
                animate(items, {
                  opacity: [0, 1],
                  translateY: [14, 0],
                  duration: 600,
                  delay: stagger(55),
                  ease: 'outCubic',
                  onComplete: () => items.forEach((el) => (el.style.willChange = 'auto')),
                });
                sio.unobserve(e.target);
              });
            },
            { threshold: 0.16, rootMargin: '0px 0px -6% 0px' }
          );
          document.querySelectorAll<HTMLElement>('[data-stagger]').forEach((el) => {
            if (el.dataset.staggerBound) return;
            el.dataset.staggerBound = 'true';
            sio.observe(el);
          });
        }
      }

      document.addEventListener('astro:page-load', init);
    </script>
  </body>
</html>
