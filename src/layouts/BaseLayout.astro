---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Self-hosted fonts (Fontsource variable). Quiet Pages is serif-led: Newsreader
// (with optical sizes + italics) is the voice, Albert Sans the caption face,
// and JetBrains Mono survives only inside code blocks.
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import '@fontsource-variable/albert-sans';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

// Preload the above-the-fold text face.
import newsreaderWoff2 from '@fontsource-variable/newsreader/files/newsreader-latin-opsz-normal.woff2?url';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
}

const { title, description, canonical, image } = Astro.props;
---

<!doctype html>
<html lang="en" data-pal="day">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Set the palette before first paint to avoid a flash. Legacy stored
         values from the previous design ("press"/"ink") migrate in place. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('pal');
          if (stored === 'press') stored = 'day';
          if (stored === 'ink') stored = 'lamp';
          var pal =
            stored === 'day' || stored === 'lamp'
              ? stored
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'lamp'
                : 'day';
          document.documentElement.dataset.pal = pal;
        } catch (e) {}
      })();
    </script>

    <link rel="preload" as="font" type="font/woff2" href={newsreaderWoff2} crossorigin />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Woo Kin Wai" href="/rss.xml" />
    <meta name="theme-color" content="#f6f1e7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1b1611" media="(prefers-color-scheme: dark)" />

    <SEO title={title} description={description} canonical={canonical} image={image} />
  </head>

  <body id="top" class="bg-paper font-serif text-[19px] leading-[1.62] text-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:border focus:border-hairline focus:bg-paper focus:px-4 focus:py-2 focus:font-sans focus:text-[13px] focus:text-ink focus:no-underline"
      >Skip to content</a
    >

    <Header />

    <main id="main"><slot /></main>
    <Footer />

    <script>
      import { animate, svg as svgUtil } from 'animejs';

      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ————— Theme toggle: day ⇄ lamplight, persisted —————
      document.getElementById('theme')?.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.dataset.pal === 'lamp' ? 'day' : 'lamp';
        root.dataset.pal = next;
        try {
          localStorage.setItem('pal', next);
        } catch (e) {}
      });

      // ————— Flowing ink rails —————
      // A container marked `.railed` with `.rail-anchor` steps gets a line of
      // ink down the gutter: drawn on first sight, then a travelling drop flows
      // step to step. Geometry is computed from the live layout so it survives
      // resizes; on narrow screens (no gutter) the rail stays hidden via CSS.
      type RailState = { line: SVGPathElement; dot: SVGCircleElement; drawn: boolean };
      const states = new Map<HTMLElement, RailState>();

      function buildRail(container: HTMLElement): void {
        container.querySelector('svg.rail')?.remove();
        if (matchMedia('(max-width: 820px)').matches) return;

        const anchors = [...container.querySelectorAll<HTMLElement>('.rail-anchor')];
        // The rail runs through the gutter left of the text column; probe that
        // column rather than the anchors (which sit in the margin column in
        // some sections and inside the text in others).
        const probe = container.querySelector('.rhs, .step');
        if (anchors.length < 2 || !probe) return;

        const cb = container.getBoundingClientRect();
        const gx = probe.getBoundingClientRect().left - cb.left - 27;
        const pts = anchors.map((a) => {
          const r = a.getBoundingClientRect();
          return { x: gx, y: r.top - cb.top + r.height / 2 };
        });

        let d = `M ${pts[0].x} ${pts[0].y}`;
        for (let i = 1; i < pts.length; i++) {
          const a = pts[i - 1];
          const b = pts[i];
          const sway = i % 2 ? 7 : -7; // a faint hand-drawn waver
          d += ` C ${a.x + sway} ${a.y + (b.y - a.y) * 0.4}, ${b.x + sway} ${b.y - (b.y - a.y) * 0.4}, ${b.x} ${b.y}`;
        }

        const NS = 'http://www.w3.org/2000/svg';
        const svg = document.createElementNS(NS, 'svg');
        svg.setAttribute('class', 'rail');
        svg.setAttribute('viewBox', `0 0 ${cb.width} ${cb.height}`);
        svg.setAttribute('preserveAspectRatio', 'none');

        const line = document.createElementNS(NS, 'path');
        line.setAttribute('class', 'rail-line');
        line.setAttribute('d', d);
        svg.appendChild(line);

        for (const p of pts) {
          const node = document.createElementNS(NS, 'circle');
          node.setAttribute('class', 'rail-node');
          node.setAttribute('cx', String(p.x));
          node.setAttribute('cy', String(p.y));
          node.setAttribute('r', '3.2');
          svg.appendChild(node);
        }

        const dot = document.createElementNS(NS, 'circle');
        dot.setAttribute('class', 'rail-dot');
        dot.setAttribute('r', '3');
        svg.appendChild(dot);

        container.appendChild(svg);
        const prev = states.get(container);
        states.set(container, { line, dot, drawn: prev?.drawn ?? false });
        if (prev?.drawn || reduced) {
          const st = states.get(container)!;
          st.drawn = true;
          st.line.style.strokeDasharray = 'none';
        }
      }

      function play(container: HTMLElement): void {
        const st = states.get(container);
        if (!st || st.drawn) return;
        st.drawn = true;
        animate(svgUtil.createDrawable(st.line), { draw: ['0 0', '0 1'], duration: 1300, ease: 'inOut(2)' });
        const path = svgUtil.createMotionPath(st.line);
        animate(st.dot, {
          translateX: path.translateX,
          translateY: path.translateY,
          opacity: [
            { to: 0.9, duration: 300 },
            { to: 0.9, duration: 2400 },
            { to: 0, duration: 400 },
          ],
          duration: 3100,
          delay: 1400,
          loop: true,
          loopDelay: 2200,
          ease: 'inOutSine',
        });
      }

      const railSections = [...document.querySelectorAll<HTMLElement>('.railed')];
      railSections.forEach(buildRail);

      if (!reduced && railSections.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                play(e.target as HTMLElement);
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.35 }
        );
        railSections.forEach((el) => io.observe(el));

        let rt: ReturnType<typeof setTimeout>;
        addEventListener('resize', () => {
          clearTimeout(rt);
          rt = setTimeout(() => railSections.forEach(buildRail), 200);
        });
      }

      // ————— The monogram's glint —————
      // Every few seconds a glaze catches the light on one tile — never the
      // whole mark at once.
      if (!reduced) {
        const marks = [...document.querySelectorAll<SVGRectElement>('.monogram rect, #sketchSeal rect')];
        if (marks.length) {
          let gi = 0;
          setInterval(() => {
            if (document.hidden) return;
            const t = marks[(gi += 7) % marks.length];
            const base = t.getAttribute('opacity') ?? '0.7';
            animate(t, { opacity: [base, 1, base], duration: 1600, ease: 'inOutSine' });
          }, 3200);
        }
      }
    </script>
  </body>
</html>
