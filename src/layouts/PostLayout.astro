---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import '../styles/prose.css';

export interface Props {
  note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const { title, description, tags, heroUrl, heroAlt, pubDate } = note.data;

const fmt = (d: Date) =>
  `${d.getUTCFullYear()} · ${String(d.getUTCMonth() + 1).padStart(2, '0')} · ${String(d.getUTCDate()).padStart(2, '0')}`;
---

<BaseLayout title={`${title} - Woo Kin Wai`} description={description}>
  <div class="pb-12 pt-[60px]">
    <header>
      <div class="font-mono text-[12px] text-soft">note · {fmt(pubDate)}</div>
      <h1 class="mt-4 font-sans text-[clamp(30px,5vw,50px)] font-semibold leading-[1.1] tracking-[-0.015em] text-ink">
        {title}
      </h1>
      <p class="mt-4 text-[17px] italic leading-[1.6] text-mut">{description}</p>
      {
        tags.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1 font-mono text-[11px] text-soft">
            {tags.map((tag) => (
              <span>/ {tag.toLowerCase()}</span>
            ))}
          </div>
        )
      }
    </header>

    {heroUrl && <img src={heroUrl} alt={heroAlt ?? ''} class="mt-8 w-full border border-rule" />}

    <div class="my-10 border-t border-rule"></div>

    <article class="prose-drafting"><slot /></article>

    <a
      href="/notes"
      class="mt-12 inline-block font-mono text-[12px] text-mut no-underline transition-colors hover:text-acc"
      >← all notes</a
    >
  </div>
</BaseLayout>
