---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Ornament from '../components/Ornament.astro';
import '../styles/prose.css';

export interface Props {
  note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const { title, description, tags, heroUrl, heroAlt, pubDate } = note.data;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
---

<BaseLayout title={`${title} - Woo Kin Wai`} description={description}>
  <div class="mx-auto max-w-[760px] px-7 pt-16">
    <header>
      <p class="caption m-0">
        {fmt(pubDate)}{tags.length > 0 && <span class="text-faint"> · {tags.join(' · ')}</span>}
      </p>
      <h1 class="mb-0 mt-3 font-serif text-[clamp(30px,4.4vw,46px)] font-[420] leading-[1.16] tracking-[-0.008em]">
        {title}
      </h1>
      <p class="mb-0 mt-4 font-serif text-[19px] italic leading-[1.55] text-soft">{description}</p>
    </header>

    {heroUrl && <img src={heroUrl} alt={heroAlt ?? ''} class="mt-8 w-full border border-hairline" />}

    <div class="my-10 flex justify-center"><Ornament /></div>

    <article class="prose-quiet"><slot /></article>

    <p class="mt-12">
      <a href="/notes" class="caption no-underline hover:underline">All notes</a>
    </p>
  </div>
</BaseLayout>
