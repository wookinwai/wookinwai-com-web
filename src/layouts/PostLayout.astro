---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

export interface Props {
  note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const { title, description, tags, heroUrl, heroAlt, pubDate } = note.data;

const fmt = (d: Date) =>
  `${d.getUTCFullYear()} · ${String(d.getUTCMonth() + 1).padStart(2, '0')} · ${String(d.getUTCDate()).padStart(2, '0')}`;
---

<BaseLayout title={`${title} — Woo Kin Wai`} description={description}>
  <div class="pt-[60px]">
    <header>
      <div class="font-mono text-[12px] uppercase tracking-[0.16em] text-soft">
        {fmt(pubDate)}
      </div>
      <h1
        class="mt-3 font-sans text-[clamp(30px,5vw,52px)] font-extrabold uppercase leading-[1.04] tracking-[-0.03em] text-ink"
      >
        {title}
      </h1>
      <p class="mt-4 text-[17px] leading-[1.6] text-mut">{description}</p>
      {
        tags.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="border-2 border-rule px-[10px] py-[5px] font-mono text-[10.5px] uppercase tracking-[0.08em] text-mut">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    {heroUrl && <img src={heroUrl} alt={heroAlt ?? ''} class="mt-8 w-full border-2 border-rule" />}

    <div class="my-10 border-t-2 border-rule"></div>

    <article class="prose-pressmono"><slot /></article>

    <a
      href="/blog"
      class="mt-12 inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.12em] text-mut no-underline transition-all hover:gap-3 hover:text-acc"
      >← All notes</a
    >
  </div>
</BaseLayout>
