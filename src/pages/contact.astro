---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import EmailButton from '../components/EmailButton.astro';
import Ticks from '../components/Ticks.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { SITE, SOCIALS, type IconName } from '../consts';
import { pageGraph } from '../lib/seo';

const title = 'Contact - Woo Kin Wai, Software Builder & Technical Partner';
const description =
  "Tell me where your business is trying to grow and what's getting in the way. Direct email, what to expect, and answers to common questions.";

const graph = pageGraph({ url: Astro.url, title, description });

// Shared spacing — same scale as the homepage sections.
const secWrap = 'reveal pt-24 max-[760px]:pt-20';

// fig. 01 — Fit
const fit = [
  'Your business has outgrown spreadsheets, manual work, or disconnected tools.',
  'You are building a new product but need help shaping the first serious version.',
  'You see an opportunity but do not yet have a technical partner.',
  'Your current systems no longer match how the business actually works.',
  'You need someone who can think through the business and build the system.',
];
const lessFit = [
  'The work is fully specified and you only need short-term implementation capacity.',
  'The decision is based only on the lowest initial price, without room to consider business fit or maintainability.',
  'The work has no real connection to a business outcome.',
];

// fig. 02 — Next
const next = [
  ['01', 'I reply', 'Usually within 1–2 business days, often sooner.'],
  [
    '02',
    'A short intro call',
    '~30 minutes to understand the business, the growth goal, and the gap. No charge, no obligation.',
  ],
  ['03', 'A clear proposal', 'Scope, approach, timeline, and how we would work together, in writing.'],
  ['04', 'We start small', 'The smallest serious version first, then iterate from real use.'],
];

// fig. 03 — FAQ (answers are trusted, controlled HTML for light emphasis)
const faqs: { q: string; a: string }[] = [
  {
    q: 'How do you charge?',
    a: 'Most work is structured as a <b class="font-semibold text-ink">fee-based project or retainer</b>. When the opportunity is strong and our interests are closely aligned, I may also work through a <b class="font-semibold text-ink">stake, revenue share, or longer-term partnership</b>.',
  },
  {
    q: 'What size of engagement do you take?',
    a: 'From a focused first build to an ongoing technical-partner role. I take on a small number of things at a time so each one gets real attention.',
  },
  {
    q: 'Do you work remotely?',
    a: "Yes. I'm based in Kuala Lumpur (GMT+8) and work with founders and SMEs remotely, meeting in person where it helps.",
  },
  {
    q: 'Will you sign an NDA?',
    a: 'Happy to. Send yours, or I can share a simple one.',
  },
  {
    q: 'What do you need from me to start?',
    a: 'A sense of where the business is trying to go and what is getting in the way. The rest we shape together.',
  },
  {
    q: "What if I'm not sure what I need yet?",
    a: 'That is a fine place to start: figuring out what to build is part of the work.',
  },
];

// fig. 04 — Direct channels (the title block)
const linkedinPath = SOCIALS[0].href.replace(/^https?:\/\/(www\.)?linkedin\.com/, '').replace(/\/$/, '');
const channels: { label: string; value: string; href?: string; external?: boolean; icon: IconName }[] = [
  { label: 'email', value: SITE.email, href: `mailto:${SITE.email}`, icon: 'email' },
  { label: 'linkedin', value: `linkedin.com${linkedinPath}`, href: SOCIALS[0].href, external: true, icon: 'linkedin' },
  { label: 'work', value: SITE.org.toLowerCase(), href: SITE.orgUrl, external: true, icon: 'work' },
  { label: 'based in', value: 'kuala lumpur · gmt+8', icon: 'location' },
];

const checklistRow =
  "relative border-b border-line py-4 pl-[34px] text-[16px] leading-[1.5] text-ink transition-all before:absolute before:left-0 before:top-4 before:font-mono before:text-[14px] before:text-acc before:content-['→'] hover:pl-[42px] hover:text-acc hover:before:left-2";
---

<BaseLayout title={title} description={description} graph={graph}>
  <!-- Hero -->
  <header class="max-w-[880px] pt-[92px] max-[760px]:pt-16">
    <div class="rise d1 mb-[30px] kicker">contact · kuala lumpur, gmt+8</div>
    <h1
      class="rise d2 mb-[30px] text-balance font-display text-[clamp(32px,5.4vw,58px)] font-extrabold leading-[1.08] tracking-[-0.018em] text-ink"
    >
      Tell me where you're trying to grow <em class="em-acc">next</em>.
    </h1>
    <p class="rise d3 max-w-[700px] text-[18.5px] leading-[1.6] text-ink">
      If your business is trying to grow and the system behind it matters, I'd like to hear about it. The fastest way to
      reach me is a short, specific email: where you're trying to go, and what's getting in the way.
    </p>
    <div class="rise d3 mt-9 flex flex-wrap items-center gap-x-8 gap-y-4">
      <EmailButton />
      <a
        href={SOCIALS[0].href}
        target="_blank"
        rel="noopener"
        class="group inline-flex items-baseline gap-1.5 font-mono text-anno-md no-underline"
      >
        <span
          class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2"
          >linkedin</span
        >
        <span
          class="text-acc transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-acc-2"
          aria-hidden="true">↗</span
        >
      </a>
    </div>
  </header>

  <!-- fig. 01 — Fit -->
  <section class={secWrap}>
    <SectionHead title="When it makes sense" em="to talk" sub="when the system behind the business starts to matter." />
    <p class="max-w-[700px] text-[17px] leading-[1.66] text-ink">
      I am especially interested in founder-led businesses, SMEs, and early ventures where the opportunity is practical,
      the constraints are real, and the technical work has to connect back to the business.
    </p>
    <ul class="m-0 mt-8 max-w-[760px] list-none border-t border-line p-0" data-stagger>
      {fit.map((item) => <li class={checklistRow}>{item}</li>)}
    </ul>

    <div class="mt-11 max-w-[640px]">
      <div class="mb-4 font-mono text-anno text-soft">probably not the right fit /</div>
      <ul class="m-0 list-none p-0" data-stagger>
        {
          lessFit.map((item) => (
            <li class="relative border-b border-line py-3 pl-[26px] text-[15px] leading-[1.5] text-mut">
              <span class="absolute left-0 top-[15px] font-mono text-[15px] leading-none text-warn" aria-hidden="true">
                ×
              </span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- fig. 02 — Next -->
  <section class={secWrap}>
    <SectionHead
      title="What happens after you"
      em="reach out"
      sub="no pressure, no long forms: a short path from email to a clear proposal."
    />
    <ol class="m-0 max-w-[760px] list-none border-t border-line p-0" data-stagger>
      {
        next.map(([n, h, p]) => (
          <li class="group grid grid-cols-[78px_1fr] items-baseline gap-[18px] border-b border-line py-6 max-[520px]:grid-cols-1 max-[520px]:gap-2">
            <div class="font-mono text-anno text-soft transition-colors group-hover:text-acc">step {n} /</div>
            <div>
              <div class="text-[19px] font-semibold italic leading-[1.15] text-ink">{h}</div>
              <p class="mt-1.5 text-[15px] leading-[1.55] text-mut">{p}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- fig. 03 — FAQ -->
  <section class={secWrap}>
    <SectionHead title="Questions people" em="ask" />
    <div class="mt-2.5 max-w-[760px] border-t border-line" data-stagger>
      {
        faqs.map((f) => (
          <div class="grid grid-cols-[220px_1fr] gap-8 border-b border-line py-6 max-[640px]:grid-cols-1 max-[640px]:gap-2">
            <div class="text-[16px] font-semibold italic leading-[1.4] text-ink">{f.q}</div>
            <p class="m-0 text-[15.5px] leading-[1.62] text-mut" set:html={f.a} />
          </div>
        ))
      }
    </div>
  </section>

  <!-- If you want to build together -->
  <section class:list={[secWrap, 'scroll-mt-4 max-[760px]:scroll-mt-12']} id="builders">
    <SectionHead
      title="For people who want to"
      em="build together."
      sub="a note for thoughtful builders, designers, operators, and technical people."
    />
    <div class="max-w-[700px]" data-stagger>
      <p class="mb-5 mt-0 text-[17px] leading-[1.66] text-ink">
        I do not always have room for new collaborations, but I am always glad to hear from people who care about useful
        work.
      </p>
      <p class="mb-0 text-[17px] leading-[1.66] text-ink">
        Send a short note with what you are good at, what kind of work you want to do more of, and one thing you have
        built or learned from.
      </p>
    </div>
  </section>

  <!-- fig. 04 — Direct channels (the title block) -->
  <section class={secWrap}>
    <SectionHead title="Direct" em="channels" />
    <div class="relative mt-2.5 max-w-[640px] border-[1.5px] border-rule bg-bg">
      <Ticks />
      {
        channels.map((c, i) => {
          const inner = (
            <div class="grid grid-cols-[140px_1fr] items-center max-[520px]:grid-cols-1">
              <span class="flex h-full items-center gap-2.5 border-r border-line px-[22px] py-[15px] font-mono text-anno text-soft max-[520px]:border-r-0 max-[520px]:pb-0">
                <SocialIcon name={c.icon} class="h-[15px] w-[15px] flex-none text-mut" />
                {c.label} /
              </span>
              <span class="px-[22px] py-[15px] font-mono text-anno-lg text-ink">
                {c.href ? (
                  <span class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2">
                    {c.value}
                  </span>
                ) : (
                  c.value
                )}
                {c.external && <span class="text-soft"> ↗</span>}
              </span>
            </div>
          );
          const edge = i > 0 ? 'border-t border-line' : '';
          return c.href ? (
            <a
              href={c.href}
              target={c.external ? '_blank' : undefined}
              rel={c.external ? 'noopener' : undefined}
              class:list={['row-edge group block no-underline transition-colors hover:bg-panel', edge]}
            >
              {inner}
            </a>
          ) : (
            <div class:list={[edge]}>{inner}</div>
          );
        })
      }
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="reveal pb-12 pt-24 max-[760px]:pt-[72px]">
    <p class="max-w-[560px] text-[18px] leading-[1.6] text-ink">
      The whole thing starts with <em class="italic text-acc">one email</em>. No form, no funnel.
    </p>
    <div class="mt-6"><EmailButton /></div>
  </section>
</BaseLayout>
