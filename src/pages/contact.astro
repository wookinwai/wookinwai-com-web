---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterOpen from '../components/ChapterOpen.astro';
import EmailButton from '../components/EmailButton.astro';
import { SITE, SOCIALS } from '../consts';

const title = 'Contact - Woo Kin Wai';
const description =
  "Tell me where your business is trying to grow and what's getting in the way. Direct email, what to expect, and answers to common questions.";

// Fit
const fit = [
  'Your business has outgrown spreadsheets, manual work, or disconnected tools.',
  'You are building a new product but need help shaping the first serious version.',
  'You see an opportunity but do not yet have a technical partner.',
  'Your current systems no longer match how the business actually works.',
  'You need someone who can think through the business and build the system.',
];
const lessFit = [
  'You need a pair of hands to close tickets on a fixed spec, with no say in the system.',
  'You are looking for the cheapest possible build rather than the right one.',
  'The work has no real connection to a business outcome.',
];

// Next — spelled steps, connected by the flowing ink rail.
const next = [
  ['First, I reply.', 'Usually within 1–2 business days, often sooner.'],
  [
    'Then, a short intro call.',
    'About 30 minutes to understand the business, the growth goal, and the gap. No charge, no obligation.',
  ],
  ['Then, a clear proposal.', 'Scope, approach, timeline, and the engagement model, in writing.'],
  ['And we start small.', 'The smallest serious version first, then iterate from real use.'],
];

// FAQ (answers are trusted, controlled HTML for light emphasis)
const faqs: { q: string; a: string }[] = [
  {
    q: 'How do you charge?',
    a: 'Two models. <b>Engaged to build</b>: a straightforward project or retainer rate. <b>Upside participation</b>: a stake, revenue share, or longer-term partnership, when the opportunity is strong and the fit is right.',
  },
  {
    q: 'What size of engagement do you take?',
    a: 'From a focused first build to an ongoing technical-partner role. I take on a small number of things at a time so each one gets real attention.',
  },
  {
    q: 'Do you work remotely?',
    a: "Yes. I'm based in Kuala Lumpur (GMT+8) and work with founders and SMEs remotely, with occasional time in person where it helps.",
  },
  {
    q: 'Will you sign an NDA?',
    a: 'Happy to. Send yours, or I can share a simple one.',
  },
  {
    q: 'What do you need from me to start?',
    a: 'A sense of where the business is trying to go and what is getting in the way. The rest we shape together.',
  },
  {
    q: "What if I'm not sure what I need yet?",
    a: 'That is a fine place to start: figuring out what to build is part of the work.',
  },
];

// Direct channels
const linkedinPath = SOCIALS[0].href.replace(/^https?:\/\/(www\.)?linkedin\.com/, '').replace(/\/$/, '');
const channels: { label: string; value: string; href?: string; external?: boolean }[] = [
  { label: 'Email', value: SITE.email, href: `mailto:${SITE.email}` },
  { label: 'LinkedIn', value: `linkedin.com${linkedinPath}`, href: SOCIALS[0].href, external: true },
  { label: 'Studio', value: SITE.org, href: SITE.orgUrl, external: true },
  { label: 'Based in', value: `${SITE.location} · GMT+8` },
];

const page = 'mx-auto max-w-[1060px] px-7';
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <header class:list={[page, 'pt-24']}>
    <h1 class="m-0 max-w-[20ch] font-serif text-[clamp(36px,4.8vw,58px)] font-[380] leading-[1.14] tracking-[-0.01em]">
      Tell me where you're trying to grow <i class="italic text-ribbon">next</i>.
    </h1>
    <p class="mt-[30px] max-w-[56ch] text-[20px] text-soft">
      If your business has a real growth problem and the system matters, I'd like to hear about it. The fastest way to
      reach me is a short, specific email: where you're trying to go, and what's getting in the way.
    </p>
    <div class="mt-8 flex flex-wrap items-baseline gap-x-7 gap-y-3">
      <EmailButton />
      <a href={SOCIALS[0].href} target="_blank" rel="noopener" class="caption no-underline hover:underline">
        or find me on {SOCIALS[0].label}
      </a>
    </div>
  </header>

  <!-- Chapter: fit -->
  <section class="pt-[110px]">
    <ChapterOpen>When it makes sense to <i>talk</i></ChapterOpen>
    <div class:list={['spread', page]}>
      <aside class="margin-note">
        Founder-led businesses, SMEs,<br />and early ventures where the<br />constraints are real.
      </aside>
      <div>
        <p class="mb-7 mt-0 text-[18.5px] text-soft">
          I am especially interested in work where the opportunity is practical and the technical work has to connect
          back to the business. It is probably a fit if:
        </p>
        <ul class="m-0 list-none p-0">
          {
            fit.map((item) => (
              <li class="border-t border-hairline py-3.5 text-[17.5px] leading-[1.55] text-ink last:border-b">
                {item}
              </li>
            ))
          }
        </ul>
        <p class="mb-3 mt-9 font-serif text-[17px] italic text-faint">Probably not the right fit:</p>
        <ul class="m-0 list-none p-0">
          {lessFit.map((item) => <li class="py-1.5 text-[16px] leading-[1.55] text-soft">{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Chapter: what happens next, with the flowing ink rail -->
  <section class="pt-[110px]">
    <ChapterOpen>What happens <i>after you reach out</i></ChapterOpen>
    <div class:list={['spread railed', page]}>
      <aside class="margin-note">
        No pressure, no long forms:<br />a short path from email<br />to a clear proposal.
      </aside>
      <div>
        {
          next.map(([lead, text]) => (
            <p class="step">
              <b class="rail-anchor">{lead}</b> {text}
            </p>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Chapter: FAQ -->
  <section class="pt-[110px]">
    <ChapterOpen>Questions people <i>ask</i></ChapterOpen>
    <div class={page}>
      {
        faqs.map((f, i) => (
          <div class:list={['spread border-t border-hairline py-6', i === faqs.length - 1 && 'border-b']}>
            <aside class="margin-note">
              <em>{f.q}</em>
            </aside>
            <p class="m-0 text-[17px] leading-[1.62] text-soft [&_b]:font-semibold [&_b]:text-ink" set:html={f.a} />
          </div>
        ))
      }
    </div>
  </section>

  <!-- Chapter: details -->
  <section class="pt-[110px]">
    <ChapterOpen>Direct <i>channels</i></ChapterOpen>
    <div class={page}>
      {
        channels.map((c, i) => (
          <div class:list={['spread border-t border-hairline py-[18px]', i === channels.length - 1 && 'border-b']}>
            <aside class="margin-note">{c.label}</aside>
            <p class="m-0 text-[17px]">
              {c.href ? (
                <a
                  href={c.href}
                  target={c.external ? '_blank' : undefined}
                  rel={c.external ? 'noopener' : undefined}
                  class="no-underline hover:text-ribbon hover:underline"
                >
                  {c.value}
                </a>
              ) : (
                c.value
              )}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Closing -->
  <section class:list={[page, 'pt-[110px] pb-[30px] text-center']}>
    <p class="mx-auto m-0 max-w-[28ch] font-serif text-[clamp(22px,2.6vw,28px)]">
      Prefer to skip the form-fields and just write? <i class="italic text-ribbon">Same here.</i>
    </p>
    <div class="mt-7"><EmailButton /></div>
  </section>
</BaseLayout>
