---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ornament from '../components/Ornament.astro';
---

<BaseLayout title="Page not found - Woo Kin Wai" description="That page does not exist.">
  <section
    class="mx-auto flex min-h-[60vh] max-w-[1060px] flex-col items-center justify-center px-7 py-[120px] text-center"
  >
    <Ornament />
    <h1 class="mb-0 mt-6 font-serif text-[clamp(32px,4.4vw,48px)] font-[380] leading-[1.14]">
      This page seems to be <i class="italic text-ribbon">missing from the book</i>.
    </h1>
    <p class="mt-4 max-w-[44ch] text-[18px] text-soft">
      The link may be broken, or the page may have moved. The table of contents above will get you back on track.
    </p>
    <p class="mt-7">
      <a href="/" class="font-serif text-[18px] italic underline decoration-ribbon decoration-1 underline-offset-[5px]"
        >Back to the first page</a
      >
    </p>
  </section>
</BaseLayout>
