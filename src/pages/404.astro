---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Woo Kin Wai" description="That page does not exist.">
  <section class="flex min-h-[60vh] flex-col items-center justify-center py-[120px] text-center">
    <div class="font-mono text-[11px] font-bold uppercase tracking-[0.22em] text-acc">404</div>
    <h1 class="mt-4 font-sans text-[clamp(32px,5vw,52px)] font-extrabold leading-[1.06] tracking-[-0.03em] text-ink">
      This page wandered off.
    </h1>
    <p class="mt-4 max-w-[460px] text-[17px] leading-[1.7] text-mut">
      The link may be broken, or the page may have moved. Let’s get you back on track.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 font-mono text-[11.5px] font-bold uppercase tracking-[0.12em] text-mut no-underline transition-all hover:gap-3 hover:text-acc"
      >← Back home</a
    >
  </section>
</BaseLayout>
