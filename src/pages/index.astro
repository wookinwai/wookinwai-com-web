---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import ShotFrame from '../components/ShotFrame.astro';
import Ticks from '../components/Ticks.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { getCollection } from 'astro:content';
import { SITE, type IconName } from '../consts';

const title = 'Woo Kin Wai: software builder & technical partner';
const description =
  'I work with founders and SMEs to shape and build the software their business needs next, from products to platforms to internal tools. Founder of Tiny Edges, Kuala Lumpur.';

// Selected work — CMS-driven (fig. 02). Closed ventures come off the card
// grid and render as a slim strip below it; the full retrospective lives on
// /work/#oryza.
const work = (await getCollection('work')).sort((a, b) => a.data.sortOrder - b.data.sortOrder);
const sheets = work.filter((entry) => entry.data.status !== 'closed');
const hasClosed = work.some((entry) => entry.data.status === 'closed');

const statusLabel = {
  live: 'live',
  building: 'in build',
  testing: 'in testing',
  ongoing: 'ongoing',
  closed: 'closed',
} as const;
const modelLabel = { upside: 'upside participation', engaged: 'engaged to build' } as const;

// fig. 01 — the schematic: growth → gap → build.
const flow = [
  {
    label: 'the growth',
    ann: 'where the business wants to go',
    desc: 'New revenue, better operations, a product idea, a platform, or a market opportunity that is starting to become real.',
  },
  {
    label: 'the gap',
    ann: 'what is getting in the way',
    desc: 'The work is still manual, scattered, unclear, or technically fragile. The ambition exists, but the operating shape does not.',
  },
  {
    label: 'the build',
    ann: 'software that can carry it',
    desc: 'A product, platform, portal, internal tool, workflow, or technical foundation designed around how the business actually works.',
    build: true,
  },
];

// fig. 03 — a few common forms the work tends to take.
const cases = [
  [
    'a',
    'A new product has to become real',
    'A founder sees the opportunity, but the first serious version still needs to be shaped, scoped, and built properly.',
  ],
  [
    'b',
    'Operations have outgrown the workaround',
    'The business runs on spreadsheets, WhatsApp, manual checks, duplicated effort, and knowledge that lives in people’s heads.',
  ],
  [
    'c',
    'A platform needs technical direction',
    'The idea is bigger than a simple website. It needs a backend, data model, workflows, integrations, and decisions that will hold up later.',
  ],
  [
    'd',
    'The business needs a technical partner',
    'Not just someone to take tickets, but someone who can understand the business, make tradeoffs, and stay close to the outcome.',
  ],
];

// fig. 05 — the drafted timeline.
const steps = [
  [
    '01',
    'Assess the situation.',
    'Understand where the business wants to grow, what is blocking it, and what cannot be ignored.',
  ],
  ['02', 'Shape the system.', 'Turn the ambition into a clear product, workflow, platform, or system design.'],
  ['03', 'Build the first version.', 'Create the smallest serious version that can be used, tested, and improved.'],
  [
    '04',
    'Refine it with reality.',
    'Ship, learn, and refine the system as the business, users, and constraints become clearer.',
  ],
];

const secWrap = 'reveal pt-24 max-[760px]:pt-20';

// contact — the title block (mirrors the contact page's Direct channels).
const ctaRows: { label: string; value: string; href?: string; icon: IconName }[] = [
  { label: 'next', value: 'the system your business needs next', icon: 'system' },
  { label: 'start with', value: 'where the business is trying to grow', icon: 'growth' },
  { label: 'based in', value: 'kuala lumpur · gmt+8', icon: 'location' },
  { label: 'write', value: SITE.email, href: `mailto:${SITE.email}`, icon: 'email' },
];
const ctaLabel =
  'flex h-full items-center gap-2.5 border-r border-line px-[22px] py-[15px] font-mono text-anno text-soft max-[560px]:border-r-0 max-[560px]:pb-0';
const ctaValue = 'px-[22px] py-[15px] font-mono text-anno-lg text-ink';
// Linkable values read as links: green text + green underline, deepening on hover.
const ctaLink = 'border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2';
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <header class="max-w-[880px] pt-[92px] pb-9 max-[760px]:pt-16">
    <div class="rise d1 mb-[30px] kicker">software builder &amp; technical partner · kuala lumpur, gmt+8</div>
    <h1
      class="rise d2 mb-[34px] text-balance font-sans text-[clamp(34px,5.4vw,64px)] font-extrabold leading-[1.08] tracking-[-0.018em] text-ink"
    >
      I help businesses shape and build the software they need for their{' '}
      <em class="em-acc">next stage of growth</em>.
    </h1>
    <div class="rise d3">
      <p class="mb-4 max-w-[700px] text-[18.5px] leading-[1.6] text-ink">
        The work usually starts before the code: where the business is trying to go, what is getting in the way, and
        what kind of system would carry it forward.
      </p>
      <p class="max-w-[700px] text-[18.5px] leading-[1.6] text-ink">
        Sometimes that means building a product from zero. Sometimes it means turning messy operations into software.
        Sometimes it means helping a founder shape the technical path before the first serious build.
      </p>
    </div>
  </header>

  <!-- fig. 01 — the schematic: growth → gap → build -->
  <figure class="rise d4 relative m-0 mt-5 border border-rule bg-bg px-14 pb-12 pt-12 max-[900px]:px-7">
    <Ticks />
    <div
      class="flow-relay grid grid-cols-[1fr_64px_1fr_64px_1fr] items-stretch max-[900px]:grid-cols-1 max-[900px]:gap-5"
    >
      {
        flow.map((f, i) => (
          <>
            {/* z-10 + opaque card fill so the pen head and its ink tail run
                BEHIND the cards and tuck under their edges */}
            <div class="relative z-10">
              <div
                class:list={[
                  'relative bg-bg px-7 pb-6 pt-[26px]',
                  f.build ? 'tick-corner border-2 border-acc' : 'border-[1.5px] border-rule',
                ]}
              >
                <div
                  class:list={['mb-2.5 text-[25px] font-bold italic leading-none', f.build ? 'text-acc' : 'text-ink']}
                >
                  {f.label}
                </div>
                <div class="font-mono text-anno leading-[1.5] text-mut">{f.ann}</div>
              </div>
              <div class="mx-1 mt-[22px] flex items-stretch gap-6">
                {/* stacked-view leader: rides the left edge of the description,
                    running the full height of the text toward the next card */}
                {i < flow.length - 1 && (
                  <div class="conn flow-conn ml-1.5 hidden shrink-0 max-[900px]:block" aria-hidden="true">
                    <span class="conn-packet" aria-hidden="true" />
                    <span class="conn-arrow" aria-hidden="true" />
                  </div>
                )}
                <p
                  class:list={[
                    'm-0 min-w-0 flex-1 text-[15px] leading-[1.55] text-mut',
                    // the build has no leader beside it; match the other
                    // descriptions' indent (leader margin + width + flex gap)
                    i === flow.length - 1 && 'max-[900px]:pl-[30px]',
                  ]}
                >
                  {f.desc}
                </p>
              </div>
            </div>
            {i < flow.length - 1 && (
              <div class="conn flow-conn mt-[58px] self-start max-[900px]:hidden" aria-hidden="true">
                {/* packet before arrow so the arrowhead paints on top and the
                    pen head tucks behind it on arrival */}
                <span class="conn-packet" aria-hidden="true" />
                <span class="conn-arrow" aria-hidden="true" />
              </div>
            )}
          </>
        ))
      }
    </div>
    <figcaption class="mt-11 border-t border-line pt-4 font-mono text-anno-md text-mut">
      from business need → to working system
    </figcaption>
  </figure>

  <!-- fig. 02 — selected work: the build sheets -->
  <section class:list={[secWrap, 'max-[760px]:scroll-mt-12']} id="work">
    <SectionHead title="Selected" em="work" />
    {/* SectionHead's own `sub` is plain text; this replicates it to carry the page link. */}
    <p class="mb-10 mt-[18px] font-mono text-anno leading-[1.55] text-soft">
      a few examples of growth needs turned into working systems.{' '}
      <a href="/work/" class="group inline-flex items-baseline gap-1.5 no-underline">
        <span
          class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2"
          >all case notes</span
        >
        <span class="text-acc transition-transform group-hover:translate-x-1 group-hover:text-acc-2" aria-hidden="true"
          >→</span
        >
      </a>
    </p>
    <div class="mb-9 mt-2 max-w-[760px]">
      <p class="m-0 text-[16px] leading-[1.6] text-ink">
        Two ways I work: a <b class="font-semibold">straightforward paid engagement</b>, or a{' '}
        <b class="font-semibold">selective longer-term partnership</b> through a stake or revenue share. Each project notes
        the model.
      </p>
      <p class="mb-0 mt-2 font-mono text-anno text-mut">
        The right model depends on the work, the relationship, and how closely our incentives should be aligned.
      </p>
    </div>
    {
      work.length === 0 && (
        <p class="mt-3 border-b border-line pb-5 font-mono text-anno text-soft">selected work will appear here.</p>
      )
    }
    {
      sheets.map((entry) => {
        const w = entry.data;
        const closed = w.status === 'closed';
        const hasShot = Boolean(w.screenshotUrl || w.shot);
        // Header meta is relationship + status only; the role gets its own
        // line below the paragraph. Everything else (opportunity, gap, what
        // was built, stack) belongs to /work/ now.
        const model = w.engagement && modelLabel[w.engagement];
        const roleLine = w.nd.find((n) => /involved|role/i.test(n.label))?.text;
        return (
          <article
            class:list={['mt-12 border bg-bg first-of-type:mt-3', closed ? 'border-dashed border-mut' : 'border-rule']}
          >
            <div
              class:list={[
                'grid grid-cols-[1fr_auto] border-b max-[900px]:grid-cols-1',
                closed ? 'border-dashed border-line' : 'border-rule',
              ]}
            >
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 px-[22px] py-4">
                <h3 class="m-0 whitespace-nowrap text-[27px] font-semibold text-ink">{w.name}</h3>
                <span class="text-[16px] italic text-mut">{w.tease}</span>
              </div>
              <div class="flex items-center gap-3.5 border-l border-line px-[22px] py-4 font-mono text-anno text-mut max-[900px]:border-l-0 max-[900px]:border-t max-[900px]:border-line max-[900px]:py-2.5">
                <span class="flex items-center gap-1.5 whitespace-nowrap">
                  <span class:list={['smark', w.status]} />
                  {statusLabel[w.status]}
                </span>
                {model && (
                  <>
                    <span class="text-soft" aria-hidden="true">
                      ·
                    </span>
                    <span class="text-acc">{model}</span>
                  </>
                )}
              </div>
            </div>
            <div class:list={['grid max-[900px]:grid-cols-1', hasShot ? 'grid-cols-[1.15fr_1fr]' : 'grid-cols-2']}>
              <div class="border-r border-line p-[30px_34px_34px] max-[900px]:border-r-0 max-[900px]:border-b max-[900px]:border-line max-[900px]:p-6">
                {hasShot ? (
                  <div>
                    <ShotFrame
                      frame={w.shotFrame}
                      src={w.screenshotUrl}
                      alt={w.screenshotAlt || w.shot?.label || `${w.name} screenshot`}
                      pill={w.shot?.url}
                      name={w.name}
                    />
                    {w.shot?.label && (
                      <div
                        class:list={[
                          'px-0.5 pt-3 font-mono text-anno-sm text-mut',
                          w.shotFrame === 'mobile' && 'text-center',
                        ]}
                      >
                        {w.shot.label}
                      </div>
                    )}
                  </div>
                ) : (
                  w.bodyHtml && (
                    <p class="m-0 text-[16.5px] leading-[1.58] text-ink [&_b]:font-semibold" set:html={w.bodyHtml} />
                  )
                )}
              </div>
              <div class="flex flex-col p-[30px_34px_34px] max-[900px]:p-6">
                {hasShot && w.bodyHtml && (
                  <p
                    class="mb-[22px] mt-0 text-[16.5px] leading-[1.58] text-ink [&_b]:font-semibold"
                    set:html={w.bodyHtml}
                  />
                )}
                {roleLine && (
                  <div class="border-t border-line pt-4 font-mono text-anno leading-[1.55] text-mut">
                    <span class="text-soft">my role /</span> {roleLine}
                  </div>
                )}
                <div class="mt-auto pt-6">
                  <a
                    href={`/work/#${entry.id}`}
                    class="group inline-flex items-baseline gap-2 font-mono text-anno-md no-underline"
                  >
                    <span class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2">
                      full case notes
                    </span>
                    <span
                      class="text-acc transition-transform group-hover:translate-x-1 group-hover:text-acc-2"
                      aria-hidden="true"
                    >
                      →
                    </span>
                  </a>
                </div>
              </div>
            </div>
          </article>
        );
      })
    }
    {
      /* Closed-venture strip — the copy is Oryza's; if another venture ever
         closes in the CMS, this block needs revisiting. */
      hasClosed && (
        <aside class="mt-12 border border-dashed border-mut bg-bg px-[26px] py-6 max-[560px]:px-5">
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
            <h3 class="m-0 text-[19px] font-semibold text-ink">Oryza Technologies</h3>
            <span class="flex items-center gap-1.5 font-mono text-anno text-mut">
              <span class="smark closed" /> closed
            </span>
          </div>
          <p class="mb-0 mt-2 max-w-[640px] text-[15.5px] leading-[1.6] text-mut">
            My first venture did not make it. I keep it on the record, because it changed how I build.
          </p>
          <a
            href="/work/#oryza"
            class="group mt-4 inline-flex items-baseline gap-2 font-mono text-anno-md no-underline"
          >
            <span class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2">
              the retrospective
            </span>
            <span
              class="text-acc transition-transform group-hover:translate-x-1 group-hover:text-acc-2"
              aria-hidden="true"
            >
              →
            </span>
          </a>
        </aside>
      )
    }
  </section>

  <!-- fig. 03 — what this usually looks like -->
  <section class={secWrap}>
    <SectionHead title="What this usually" em="looks like" sub="a few common forms the work tends to take." />
    <div class="grid grid-cols-2 gap-x-[72px] max-[760px]:grid-cols-1" data-stagger>
      {
        cases.map(([, h, p]) => (
          <div class="border-b border-line py-[26px]">
            <h3 class="mb-2 mt-0 text-[21.5px] font-semibold leading-[1.3] text-ink">{h}</h3>
            <p class="m-0 text-[15.5px] text-mut">{p}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- fig. 04 — about -->
  <section class:list={[secWrap, 'max-[760px]:scroll-mt-12']} id="about">
    <SectionHead title="The person behind" em="the work" />
    <div
      class="mt-2.5 grid grid-cols-[1fr_300px] items-start gap-20 max-[900px]:grid-cols-1 max-[900px]:gap-9"
      data-stagger
    >
      <div>
        <p class="mb-5 mt-0 text-[19px] leading-[1.62] text-ink">
          I trained as an engineer, but found my work in software, products, and systems.
        </p>
        <p class="mb-5 text-[19px] leading-[1.62] text-ink">
          Over time, I moved from writing code to leading technical work, supporting the systems behind a company as it
          grew from a small team of around ten people to about a hundred. That shaped how I see software: not just as
          clean code, but as a system that has to fit the business, the people, the timing, the constraints, and the
          next stage of growth.
        </p>
        <p class="mb-0 text-[19px] leading-[1.62] text-ink">
          Today I run Tiny Edges. I work with founders and SMEs to shape and build the software their business needs
          next. I lead the work personally and, when the build requires it, bring in a small team through Tiny Edges
          across software and design. Sometimes it is a straightforward build. Sometimes, when the opportunity is strong
          and the fit is right, I work closer to the outcome through a stake, revenue share, or longer-term partnership.
        </p>
      </div>
      <aside class="relative border border-rule bg-bg p-3.5 max-[900px]:max-w-[300px]">
        <Ticks />
        <img
          src="/woo-kin-wai-software-builder.avif"
          alt="Woo Kin Wai, software builder and technical partner"
          width="1500"
          height="1497"
          loading="lazy"
          decoding="async"
          class="block w-full saturate-[.9] contrast-[1.02]"
        />
        <div class="flex justify-between px-0.5 pb-0.5 pt-3 font-mono text-anno-sm text-mut">
          <span>woo kin wai</span>
          <span>kuala lumpur</span>
        </div>
      </aside>
    </div>
    <div
      class="relative mt-[72px] flex items-baseline gap-10 border border-rule bg-bg px-14 py-12 max-[760px]:flex-col max-[760px]:gap-4 max-[760px]:px-7 max-[760px]:py-9"
    >
      <Ticks />
      <span class="whitespace-nowrap font-mono text-anno text-acc">the working question /</span>
      <blockquote class="m-0 text-[clamp(23px,3vw,31px)] font-medium italic leading-[1.35] text-ink">
        What system does this business need in order to grow?
      </blockquote>
    </div>
    <a href="/about/" class="group mt-8 inline-flex items-baseline gap-2.5 font-mono text-anno-md no-underline">
      <span class="text-soft">more /</span>
      <span
        class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2"
        >how i think about the work, and what keeps me going</span
      >
      <span class="text-acc transition-transform group-hover:translate-x-1 group-hover:text-acc-2" aria-hidden="true"
        >→</span
      >
    </a>
  </section>

  <!-- fig. 05 — how the work unfolds -->
  <section class:list={[secWrap, 'max-[760px]:scroll-mt-12']} id="process">
    <SectionHead title="How the work" em="unfolds" sub="start small enough to learn, serious enough to matter." />
    <div class="tl-line mx-[30px] mt-[70px] max-[760px]:hidden">
      {
        /* packet before arrow so the arrowhead paints on top and the pen head
          tucks behind it on arrival */
      }
      <span class="conn-packet" aria-hidden="true"></span>
      <span class="conn-arrow" aria-hidden="true"></span>
    </div>
    <div
      class="tl-stops mx-[30px] grid grid-cols-4 max-[760px]:mx-0 max-[760px]:grid-cols-1 max-[760px]:gap-9"
      data-stagger
    >
      {
        steps.map(([id, h, p]) => (
          <div class="tl-stop relative pr-9 pt-[30px] max-[760px]:pl-[34px] max-[760px]:pr-0 max-[760px]:pt-0">
            <span class="tl-mark" aria-hidden="true" />
            <div class="mb-3 font-mono text-anno text-soft">step {id} /</div>
            <h3 class="mb-2 mt-0 text-[21px] font-semibold italic text-ink">{h}</h3>
            <p class="m-0 text-[15px] text-mut">{p}</p>
          </div>
        ))
      }
    </div>
    <a href="/process/" class="group mt-8 inline-flex items-baseline gap-2.5 font-mono text-anno-md no-underline">
      <span class="text-soft">more /</span>
      <span
        class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2"
        >why this process is important</span
      >
      <span class="text-acc transition-transform group-hover:translate-x-1 group-hover:text-acc-2" aria-hidden="true"
        >→</span
      >
    </a>
  </section>

  <!-- contact — the title block -->
  <section class="reveal pb-12 pt-[110px] max-[760px]:pt-20 max-[760px]:scroll-mt-12" id="contact">
    <p
      class="mx-auto mb-14 max-w-[760px] text-balance text-center text-[clamp(26px,3.6vw,40px)] font-extrabold leading-[1.25] tracking-[-0.01em] text-ink"
    >
      If you can describe where your business is trying to grow,{' '}
      <em class="em-acc">I can help you work out the system it needs.</em>
    </p>
    <div class="relative mx-auto max-w-[820px] border-[1.5px] border-rule bg-bg">
      <Ticks />
      {
        ctaRows.map((r, i) => {
          const inner = (
            <div class="grid grid-cols-[200px_1fr] max-[560px]:grid-cols-1">
              <span class={ctaLabel}>
                <SocialIcon name={r.icon} class="h-[15px] w-[15px] flex-none text-mut" />
                {r.label} /
              </span>
              <span class={ctaValue}>{r.href ? <span class={ctaLink}>{r.value}</span> : r.value}</span>
            </div>
          );
          const edge = i > 0 ? 'border-t border-line' : '';
          return r.href ? (
            <a href={r.href} class:list={['row-edge group block no-underline transition-colors hover:bg-panel', edge]}>
              {inner}
            </a>
          ) : (
            <div class:list={[edge]}>{inner}</div>
          );
        })
      }
    </div>
    <p class="mt-7 text-center font-mono text-anno">
      <a href="/contact/" class="group inline-flex items-baseline gap-2 no-underline">
        <span
          class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2"
          >see the contact page to check fit, first steps, and common questions.</span
        >
        <span class="text-acc transition-transform group-hover:translate-x-1 group-hover:text-acc-2" aria-hidden="true"
          >→</span
        >
      </a>
    </p>
  </section>
</BaseLayout>

<script>
  // Relays, ported from the previous design and redrawn in drafting language.
  //
  // fig. 01 — growth → gap → build: an anime.js timeline sends a green "pen
  // head" down each dashed leader line in turn; the arrowhead pulses as it
  // arrives. The packet is the work moving through the system.
  //
  // fig. 05 — the drafted timeline: the same pen head travels the baseline
  // stop to stop, and each square marker pulses as the work passes through it
  // (listen → shape → build → stay close), fading out at the arrowhead.
  //
  // The other sections stay still on purpose: cases, sheets, and the title
  // block have no direction to animate — motion there would be noise. Both
  // relays run only while on screen, skip entirely under reduced motion, and
  // rebind cleanly across View-Transition navigations.
  import { createTimeline } from 'animejs';

  const STEP = 720; // fig. 01 — travel time per leader line
  const WALK = 1400; // fig. 05 — travel time per baseline segment (a slower, surveying pace)
  const OVERLAP = 100; // how much the next segment fires before the last lands
  const DWELL = 660; // pause between loops

  let tls: ReturnType<typeof createTimeline>[] = [];
  let ios: IntersectionObserver[] = [];

  function teardown() {
    ios.forEach((io) => io.disconnect());
    ios = [];
    tls.forEach((tl) => {
      tl.pause();
      tl.revert();
    });
    tls = [];
    // drop any ticked timeline stops so a fresh run starts from empty squares
    document.querySelectorAll('.tl-mark.is-done').forEach((m) => m.classList.remove('is-done'));
  }

  // play/pause a timeline as its host scrolls in and out of view
  function bind(watch: HTMLElement, tl: ReturnType<typeof createTimeline>) {
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => (e.isIntersecting ? tl.play() : tl.pause())),
      { threshold: 0.25 }
    );
    io.observe(watch);
    ios.push(io);
    tls.push(tl);
  }

  const visible = (el: HTMLElement | null): el is HTMLElement => !!el && el.getClientRects().length > 0;

  function initRelays() {
    teardown();
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // fig. 01 — leader-line relay
    const flow = document.querySelector<HTMLElement>('.flow-relay');
    const conns = flow ? [...flow.querySelectorAll<HTMLElement>('.flow-conn')].filter(visible) : [];
    if (flow && conns.length) {
      flow.classList.add('flow-live');
      const tl = createTimeline({ loop: true, autoplay: false, defaults: { ease: 'inOutQuad' } });
      let at = 0;
      conns.forEach((conn) => {
        const packet = conn.querySelector<HTMLElement>('.conn-packet');
        const arrow = conn.querySelector<HTMLElement>('.conn-arrow');
        if (!packet) return;
        // the stacked mobile schematic turns the leader upright, so the pen
        // head travels top-to-bottom instead of left-to-right
        const upright = conn.offsetHeight > conn.offsetWidth;
        tl.add(
          packet,
          {
            ...(upright ? { top: ['0%', '100%'] } : { left: ['0%', '100%'] }),
            // fade in fast, ride the line lit, snuff out on arrival
            opacity: [
              { to: 1, duration: 70 },
              { to: 1, duration: 560 },
              { to: 0, duration: 90 },
            ],
            duration: STEP,
          },
          at
        );
        if (arrow) {
          tl.add(arrow, { scale: [1, 1.5, 1], duration: 340, ease: 'outQuad' }, at + STEP - 190);
        }
        at += STEP - OVERLAP;
      });
      // hold on the empty line before the relay loops
      const first = conns[0].querySelector<HTMLElement>('.conn-packet');
      if (first) tl.add(first, { opacity: 0, duration: DWELL }, at);
      bind(flow, tl);
    }

    // fig. 05 — baseline walk: stop to stop, pulsing each marker on arrival
    const line = document.querySelector<HTMLElement>('.tl-line');
    const stops = document.querySelector<HTMLElement>('.tl-stops');
    const packet = line?.querySelector<HTMLElement>('.conn-packet');
    const arrow = line?.querySelector<HTMLElement>('.conn-arrow');
    const marks = stops ? [...stops.querySelectorAll<HTMLElement>('.tl-mark')] : [];
    if (visible(line) && packet && stops && marks.length === 4) {
      line.classList.add('flow-live');
      const tl = createTimeline({ loop: true, autoplay: false, defaults: { ease: 'inOutQuad' } });
      let at = 0;
      // a stop is "ticked" green as the pen head reaches it, like a checkbox
      const tick = (m: HTMLElement) => m.classList.add('is-done');
      // set off from the first stop… (clear the board at the top of each loop)
      tl.add(
        marks[0],
        {
          scale: [1, 1.4, 1],
          duration: 300,
          ease: 'outQuad',
          onBegin: () => {
            marks.forEach((m) => m.classList.remove('is-done'));
            tick(marks[0]);
          },
        },
        0
      );
      tl.add(packet, { opacity: [0, 1], duration: 90 }, 0);
      // …walk the three segments between the four stops, ticking each on arrival…
      for (let k = 0; k < 3; k++) {
        tl.add(packet, { left: [`${k * 25}%`, `${(k + 1) * 25}%`], duration: WALK }, at);
        tl.add(
          marks[k + 1],
          { scale: [1, 1.4, 1], duration: 360, ease: 'outQuad', onBegin: () => tick(marks[k + 1]) },
          at + WALK - 200
        );
        at += WALK - OVERLAP;
      }
      // …then run off the end of the drawing
      tl.add(
        packet,
        {
          left: ['75%', '100%'],
          opacity: [
            { to: 1, duration: WALK - 120 },
            { to: 0, duration: 120 },
          ],
          duration: WALK,
        },
        at
      );
      if (arrow) {
        tl.add(arrow, { scale: [1, 1.5, 1], duration: 380, ease: 'outQuad' }, at + WALK - 230);
      }
      tl.add(packet, { opacity: 0, duration: DWELL }, at + WALK);
      bind(stops, tl);
    } else if (stops && marks.length === 4 && marks.every(visible)) {
      // stacked layout (the baseline is hidden): the relay becomes a checklist
      // running down the left rail — each stop ticks green in turn, the full
      // list holds for a beat, then the board clears and rests before looping.
      const tl = createTimeline({ loop: true, autoplay: false });
      let at = 0;
      marks.forEach((m) => {
        tl.add(
          m,
          { scale: [1, 1.35, 1], duration: 420, ease: 'outQuad', onBegin: () => m.classList.add('is-done') },
          at
        );
        at += 820;
      });
      // hold the completed list, wipe it, then rest before the next pass
      tl.add(
        marks[0],
        { scale: 1, duration: 900, onComplete: () => marks.forEach((m) => m.classList.remove('is-done')) },
        at + 600
      );
      tl.add(marks[0], { scale: 1, duration: DWELL }, at + 1500);
      bind(stops, tl);
    }
  }

  document.addEventListener('astro:page-load', initRelays);
  document.addEventListener('astro:before-swap', teardown);

  // the relays swap shape at the layout breakpoints (fig. 01 flips axis at
  // 900px, fig. 05 loses its baseline at 760px), so rebuild when a breakpoint
  // is crossed. Listen to matchMedia changes, NOT window resize: on phones,
  // scrolling collapses the URL bar and fires resize constantly, and a
  // resize-driven rebuild kept resetting the relay to zero mid-scroll —
  // which read as the animation never running at all.
  for (const bp of ['(max-width: 900px)', '(max-width: 760px)']) {
    window.matchMedia(bp).addEventListener('change', () => initRelays());
  }
</script>

<script>
  // process timeline: rows fade up once on scroll-in, then a glowing accent
  // "spark" rides the rail node → node (lighting each as it arrives), holds at
  // the end, resets, and loops while the section is on screen. Node y-positions
  // are measured from layout, so the loop is rebuilt on a debounced resize.
  // Skips entirely when motion is off (no-JS / reduced-motion) and rebinds
  // cleanly across View-Transition navigations.
  import { animate, stagger, createTimeline } from 'animejs';

  let entranceIo: IntersectionObserver | null = null;
  let playIo: IntersectionObserver | null = null;
  let tl: ReturnType<typeof createTimeline> | null = null;
  let spark: HTMLElement | null = null;
  let onResize: (() => void) | null = null;
  let resizeTimer = 0;

  function teardownProc() {
    entranceIo?.disconnect();
    entranceIo = null;
    playIo?.disconnect();
    playIo = null;
    tl?.pause();
    tl?.revert();
    tl = null;
    if (onResize) {
      window.removeEventListener('resize', onResize);
      onResize = null;
    }
    spark?.remove();
    spark = null;
    document.querySelectorAll<HTMLElement>('.proc-node.is-active').forEach((n) => n.classList.remove('is-active'));
  }

  // (re)build the looping spark against the current layout — also what the
  // debounced resize handler calls, since node centres are pixel-based.
  function buildSpark(proc: HTMLElement, nodes: HTMLElement[]) {
    playIo?.disconnect();
    playIo = null;
    tl?.pause();
    tl?.revert();
    tl = null;
    spark?.remove();
    nodes.forEach((n) => n.classList.remove('is-active'));

    spark = document.createElement('span');
    spark.className = 'proc-spark';
    proc.appendChild(spark);

    const base = proc.getBoundingClientRect();
    const first = nodes[0].getBoundingClientRect();
    const x = first.left - base.left + first.width / 2;
    const ys = nodes.map((n) => {
      const r = n.getBoundingClientRect();
      return r.top - base.top + r.height / 2;
    });
    spark.style.left = `${x}px`;
    spark.style.top = `${ys[0]}px`;

    const STEP = 520; // travel time between adjacent nodes
    const DWELL = 150; // pause on each node
    const HOLD = 700; // pause at the end before the reset

    tl = createTimeline({ loop: true, autoplay: false, defaults: { ease: 'inOutQuad' } });

    // light the first node as the spark fades in
    tl.add(
      spark,
      { opacity: [0, 1], duration: 220, ease: 'outQuad', onBegin: () => nodes[0].classList.add('is-active') },
      0
    );
    let at = DWELL;
    for (let i = 0; i < nodes.length - 1; i++) {
      const next = nodes[i + 1];
      tl.add(spark, { top: [ys[i], ys[i + 1]], duration: STEP, onComplete: () => next.classList.add('is-active') }, at);
      at += STEP + DWELL;
    }
    // hold on the full rail, then snuff spark + nodes and drop back to the top
    tl.add(spark, { opacity: [1, 0], duration: 260, ease: 'outQuad' }, at + HOLD);
    tl.add(
      spark,
      { top: ys[0], duration: 1, onBegin: () => nodes.forEach((n) => n.classList.remove('is-active')) },
      at + HOLD + 260
    );

    playIo = new IntersectionObserver(
      (entries) => entries.forEach((e) => (e.isIntersecting ? tl?.play() : tl?.pause())),
      { threshold: 0.25 }
    );
    playIo.observe(proc);
  }

  function initProc() {
    teardownProc();

    if (!document.documentElement.classList.contains('motion')) return;

    const proc = document.querySelector<HTMLElement>('.proc');
    if (!proc) return;

    const steps = [...proc.querySelectorAll<HTMLElement>('.proc-step')];
    const nodes = [...proc.querySelectorAll<HTMLElement>('.proc-node')];
    if (!steps.length || !nodes.length) return;

    entranceIo = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          entranceIo?.unobserve(e.target);

          // rows fade up once; build the spark only after they settle, so node
          // y-positions are measured at rest (the rows translateY during this).
          animate(steps, {
            opacity: [0, 1],
            translateY: [12, 0],
            duration: 560,
            delay: stagger(90),
            ease: 'outCubic',
            onComplete: () => {
              steps.forEach((el) => (el.style.willChange = 'auto'));
              buildSpark(proc, nodes);
            },
          });
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -8% 0px' }
    );
    entranceIo.observe(proc);

    onResize = () => {
      if (!spark) return; // only after the first build
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => buildSpark(proc, nodes), 160);
    };
    window.addEventListener('resize', onResize);
  }

  document.addEventListener('astro:page-load', initProc);
  document.addEventListener('astro:before-swap', teardownProc);
</script>
