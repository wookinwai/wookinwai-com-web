---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChapterOpen from '../components/ChapterOpen.astro';
import HeroSketch from '../components/HeroSketch.astro';
import EmailButton from '../components/EmailButton.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../consts';

const title = 'Woo Kin Wai: software builder & technical partner';
const description =
  'I work with founders and SMEs to shape and build the software their business needs next, from products to platforms to internal tools. Founder of Tiny Edges, Kuala Lumpur.';

// Selected work — CMS-driven.
const work = (await getCollection('work')).sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const statusLabel = { live: 'In production', building: 'In build', closed: 'Closed' } as const;
const statusTone = { live: 'text-ribbon', building: 'text-soft', closed: 'text-faint' } as const;
const modelLabel = { upside: 'upside participation', engaged: 'engaged to build' } as const;

// The argument: how growth becomes software.
const argument = [
  {
    lead: 'the growth',
    head: 'Where the business wants to go.',
    text: 'New revenue, better operations, a product idea, a platform, or a market opportunity that is starting to become real.',
  },
  {
    lead: 'the gap',
    head: 'The system is missing.',
    text: 'The work is still manual, scattered, unclear, or technically fragile. The ambition exists, but the operating shape does not.',
  },
  {
    lead: 'the build',
    head: 'Software that can carry it.',
    text: 'A product, platform, portal, internal tool, workflow, or technical foundation designed around how the business actually works.',
  },
];

const scenarios = [
  [
    'A new product has to become real',
    'A founder sees the opportunity, but the first serious version still needs to be shaped, scoped, architected, and built.',
  ],
  [
    'Operations have outgrown the workaround',
    "The business runs on spreadsheets, WhatsApp, manual checks, duplicated effort, and knowledge that lives in people's heads.",
  ],
  [
    'A platform needs technical direction',
    'The idea is bigger than a simple website. It needs a backend, data model, workflows, integrations, and decisions that will hold up later.',
  ],
  [
    'The business needs a technical partner',
    'Not just someone to take tickets, but someone who can understand the business, make tradeoffs, and stay close to the outcome.',
  ],
];

const steps = [
  ['First, listen.', 'Understand where the business wants to grow, what is blocking it, and what cannot be ignored.'],
  ['Then, shape.', 'Turn the ambition into a clear product, workflow, platform, or system design.'],
  ['Then, build.', 'Create the smallest serious version that can be used, tested, and improved.'],
  ['And stay close.', 'Ship, learn, adjust. Where I share in the upside, I stay close to the outcome.'],
];

const page = 'mx-auto max-w-[1060px] px-7';
---

<BaseLayout title={title} description={description}>
  <!-- Hero: text beside the ink sketch -->
  <section
    class:list={[
      page,
      'grid grid-cols-[minmax(0,1fr)_340px] items-start gap-[72px] pt-24 max-[980px]:grid-cols-1 max-[980px]:gap-10',
    ]}
  >
    <div>
      <h1 class="m-0 max-w-[19ch] font-serif text-[clamp(38px,5vw,60px)] font-[380] leading-[1.14] tracking-[-0.01em]">
        I help businesses define and build the software they need for their <i class="italic text-ribbon"
          >next stage of growth</i
        >.
      </h1>
      <p class="mt-[30px] max-w-[56ch] text-[20px] text-soft">
        The work usually starts before the code: where the business is trying to go, what is getting in the way, and
        what kind of system would actually help it move.
      </p>
      <p class="mt-3.5 max-w-[56ch] text-[20px] text-soft">
        Sometimes that means building a product from zero. Sometimes it means turning messy operations into software.
        Sometimes it means helping a founder shape the technical path before the first serious build.
      </p>
      <p class="mt-7 font-sans text-[13px] text-faint">
        Software builder &amp; technical partner — founder of <b class="font-semibold text-soft">{SITE.org}</b>, Kuala
        Lumpur, Malaysia.
      </p>
    </div>
    <HeroSketch />
  </section>

  <!-- The argument: growth → gap → build, with a flowing ink rail -->
  <section class:list={[page, 'railed mt-[76px] border-t border-hairline']} aria-label="How growth becomes software">
    {
      argument.map((a) => (
        <div class="spread border-b border-hairline py-[26px]">
          <div class="rail-anchor text-right font-serif text-[17px] italic text-ribbon max-[820px]:text-left">
            {a.lead}
          </div>
          <div class="rhs">
            <p class="m-0 text-[17.5px] text-soft">
              <b class="font-semibold text-ink">{a.head}</b> {a.text}
            </p>
          </div>
        </div>
      ))
    }
  </section>

  <!-- Chapter: the pattern -->
  <section class="pt-[110px]" id="pattern">
    <ChapterOpen>What this usually <i>looks like</i></ChapterOpen>
    <div class:list={['spread', page]}>
      <aside class="margin-note">Four shapes the same<br />conversation tends to take.</aside>
      <div>
        {
          scenarios.map(([head, text]) => (
            <p class="runin">
              <b>{head}</b>
              {text}
            </p>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Chapter: about -->
  <section class="pt-[110px]" id="about">
    <ChapterOpen>The short <i>version</i></ChapterOpen>
    <div class:list={['spread', page]}>
      <aside class="margin-note">
        <em>Kin Wai</em><br />{SITE.location}<br /><br />Engineer, then technical<br />lead, then founder.
      </aside>
      <div>
        <img
          src="/woo-kin-wai-software-builder.avif"
          alt="Woo Kin Wai, software builder and technical partner"
          width="1500"
          height="1497"
          loading="lazy"
          decoding="async"
          class="float-right ml-[26px] mb-4 mt-1.5 aspect-[4/5] w-[168px] border border-hairline object-cover max-[820px]:ml-4 max-[820px]:w-[130px]"
        />
        <p class="mb-4 mt-0">
          I started as an engineer, then spent a decade as the person responsible for turning ideas into working
          systems.
        </p>
        <p class="mb-4 mt-0">
          Over time, I moved from writing code to leading technical work, helping scale a company from a small team of
          around ten people to about a hundred. That experience shaped how I see software: good software is not just
          clean code. It is a system that fits the business, the people, the timing, the constraints, and the next stage
          of growth.
        </p>
        <p class="mb-4 mt-0">
          Today I run <b class="font-semibold">{SITE.org}</b>. I work with founders and SMEs to shape and build the
          software their business needs next. Sometimes it is a straightforward build. Sometimes, when the opportunity
          is strong and the fit is right, I work closer to the outcome through a stake, revenue share, or longer-term
          partnership.
        </p>
      </div>
    </div>
    <blockquote class="colophon-quote">What system does this business need in order to grow?</blockquote>
  </section>

  <!-- Chapter: selected work -->
  <section class="pt-[110px]" id="work">
    <ChapterOpen>Selected <i>work</i></ChapterOpen>

    <div class={page}>
      <div class="spread mb-[26px]">
        <aside class="margin-note">As of May 2026.</aside>
        <p class="m-0 text-[18px] text-soft">
          A few examples of growth needs turned into working systems, from founder-led products to platforms and
          internal tools.
        </p>
      </div>

      {
        work.length === 0 && (
          <div class="spread border-t border-hairline py-[30px]">
            <aside class="margin-note" />
            <p class="m-0 font-serif italic text-faint">Selected work will appear here.</p>
          </div>
        )
      }
      {
        work.map((entry, i) => {
          const w = entry.data;
          return (
            <article
              class:list={['spread border-t border-hairline py-[38px] pb-[30px]', i === work.length - 1 && 'border-b']}
            >
              <aside class="margin-note">
                <span class:list={['font-semibold', statusTone[w.status]]}>{statusLabel[w.status]}</span>
                {w.engagement && (
                  <>
                    <br />
                    {modelLabel[w.engagement]}
                  </>
                )}
                {w.role && (
                  <>
                    <br />
                    {w.role.toLowerCase()}
                  </>
                )}
                {w.stack.length > 0 && (
                  <>
                    <br />
                    <em>{w.stack.join(' · ')}</em>
                  </>
                )}
              </aside>
              <div>
                <h3 class="m-0 mb-2 font-serif text-[27px] font-[480] tracking-[-0.005em]">
                  {w.visit ? (
                    <a
                      href={w.visit.href}
                      target="_blank"
                      rel="noopener"
                      class="no-underline hover:text-ribbon hover:underline"
                    >
                      {w.name}
                    </a>
                  ) : (
                    w.name
                  )}
                </h3>
                <p class="m-0 max-w-[58ch] text-[18px] text-soft">{w.tease}</p>
                {w.screenshotUrl && (
                  <figure class="m-0 mt-5 max-w-[560px]">
                    <img
                      src={w.screenshotUrl}
                      alt={w.shot?.label || `${w.name} screenshot`}
                      loading="lazy"
                      decoding="async"
                      class="w-full border border-hairline"
                    />
                    {w.shot?.label && (
                      <figcaption class="mt-2 font-serif text-[13.5px] italic text-faint">{w.shot.label}</figcaption>
                    )}
                  </figure>
                )}
                {w.bodyHtml && (
                  <div
                    class="mt-4 max-w-[58ch] text-[17px] text-soft [&_b]:font-semibold [&_b]:text-ink [&_p]:mb-3 [&_p]:mt-0"
                    set:html={w.bodyHtml}
                  />
                )}
                {w.nd.length > 0 && (
                  <dl class="m-0 mt-4 grid max-w-[58ch] grid-cols-[auto_1fr] gap-x-5 gap-y-1.5 border-t border-hairline pt-4">
                    {w.nd.map((n) => (
                      <>
                        <dt class="caption pt-[3px]">{n.label}</dt>
                        <dd class="m-0 text-[15.5px] text-ink">{n.text}</dd>
                      </>
                    ))}
                  </dl>
                )}
                {w.visit && (
                  <a
                    href={w.visit.href}
                    target="_blank"
                    rel="noopener"
                    class="mt-5 inline-block font-serif text-[16px] italic underline decoration-ribbon decoration-1 underline-offset-[4px]"
                  >
                    {w.visit.label.replace(/\s*↗\s*$/, '')}
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </section>

  <!-- Chapter: process, with a flowing ink rail -->
  <section class="pt-[110px]" id="process">
    <ChapterOpen>How the work <i>unfolds</i></ChapterOpen>
    <div class:list={['spread railed', page]}>
      <aside class="margin-note">Small, serious versions.<br />Then iteration.</aside>
      <div>
        {
          steps.map(([lead, text]) => (
            <p class="step">
              <b class="rail-anchor">{lead}</b> {text}
            </p>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Closing -->
  <section class:list={[page, 'pt-[110px] pb-[30px] text-center']} id="contact">
    <p class="mx-auto m-0 max-w-[26ch] font-serif text-[clamp(24px,3vw,32px)]">
      If you can describe where your business is trying to grow, <i class="italic text-ribbon"
        >I can help you work out the system it needs.</i
      >
    </p>
    <div class="mt-[30px]">
      <EmailButton />
    </div>
    <p class="mt-5">
      <a href="/contact" class="caption no-underline hover:underline"
        >What to expect, fit, and FAQ — on the contact page</a
      >
    </p>
  </section>
</BaseLayout>
