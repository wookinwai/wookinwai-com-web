---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import EmailButton from '../components/EmailButton.astro';
import Ticks from '../components/Ticks.astro';
import { SITE } from '../consts';
import { getCollection } from 'astro:content';

const title = 'Woo Kin Wai: software builder & technical partner';
const description =
  'I work with founders and SMEs to shape and build the software their business needs next, from products to platforms to internal tools. Founder of Tiny Edges, Kuala Lumpur.';

// Selected work — CMS-driven (fig. 04).
const work = (await getCollection('work')).sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const statusLabel = { live: 'live', building: 'in build', closed: 'closed' } as const;
const modelLabel = { upside: 'upside participation', engaged: 'engaged to build' } as const;

// fig. 01 — the schematic: growth → gap → build.
const flow = [
  {
    label: 'the growth',
    ann: 'where the business wants to go',
    lead: 'Where the business wants to go.',
    desc: 'New revenue, better operations, a product idea, a platform, or a market opportunity that is starting to become real.',
  },
  {
    label: 'the gap',
    ann: 'the system is missing',
    lead: 'The system is missing.',
    desc: 'The work is still manual, scattered, unclear, or technically fragile. The ambition exists, but the operating shape does not.',
  },
  {
    label: 'the build',
    ann: 'software that can carry it',
    lead: 'Software that can carry it.',
    desc: 'A product, platform, portal, internal tool, workflow, or technical foundation designed around how the business actually works.',
    build: true,
  },
];

// fig. 02 — four shapes the same conversation tends to take.
const cases = [
  [
    'a',
    'A new product has to become real',
    'A founder sees the opportunity, but the first serious version still needs to be shaped, scoped, architected, and built.',
  ],
  [
    'b',
    'Operations have outgrown the workaround',
    'The business runs on spreadsheets, WhatsApp, manual checks, duplicated effort, and knowledge that lives in people’s heads.',
  ],
  [
    'c',
    'A platform needs technical direction',
    'The idea is bigger than a simple website. It needs a backend, data model, workflows, integrations, and decisions that will hold up later.',
  ],
  [
    'd',
    'The business needs a technical partner',
    'Not just someone to take tickets, but someone who can understand the business, make tradeoffs, and stay close to the outcome.',
  ],
];

// fig. 05 — the drafted timeline.
const steps = [
  [
    '01',
    'First, listen.',
    'Understand where the business wants to grow, what is blocking it, and what cannot be ignored.',
  ],
  ['02', 'Then, shape.', 'Turn the ambition into a clear product, workflow, platform, or system design.'],
  ['03', 'Then, build.', 'Create the smallest serious version that can be used, tested, and improved.'],
  ['04', 'And stay close.', 'Ship, learn, adjust. Where I share in the upside, I stay close to the outcome.'],
];

const secWrap = 'reveal pt-24 max-[760px]:pt-20';
const factRow =
  'grid grid-cols-[168px_1fr] gap-[18px] border-b border-line py-3 max-[560px]:grid-cols-1 max-[560px]:gap-1';
const factKey = 'pt-[3px] font-mono text-[11.5px] text-soft max-[560px]:pt-0';
const factVal = 'm-0 text-[14.5px] leading-[1.5] text-mut';
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <header class="max-w-[880px] pt-[92px] pb-9 max-[760px]:pt-16">
    <div class="rise d1 mb-[30px] font-mono text-[12.5px] tracking-[0.04em] text-acc">
      software builder &amp; technical partner — kuala lumpur, gmt+8
    </div>
    <h1
      class="rise d2 mb-[34px] text-balance font-sans text-[clamp(34px,5.4vw,64px)] font-semibold leading-[1.08] tracking-[-0.018em] text-ink"
    >
      I help businesses define and build the software they need for their
      <em class="font-medium italic text-acc">next stage of growth</em>.
    </h1>
    <div class="rise d3">
      <p class="mb-4 max-w-[700px] text-[18.5px] leading-[1.6] text-mut">
        The work usually starts before the code: where the business is trying to go, what is getting in the way, and
        what kind of system would actually help it move.
      </p>
      <p class="max-w-[700px] text-[18.5px] leading-[1.6] text-mut">
        Sometimes that means building a product from zero. Sometimes it means turning messy operations into software.
        Sometimes it means helping a founder shape the technical path before the first serious build.
      </p>
    </div>
  </header>

  <!-- fig. 01 — the schematic: growth → gap → build -->
  <figure
    class="rise d4 relative m-0 mt-5 border border-rule bg-bg px-14 pb-12 pt-[60px] max-[900px]:px-7 max-[900px]:pt-12"
  >
    <Ticks />
    <div
      class="flow-relay grid grid-cols-[1fr_64px_1fr_64px_1fr] items-stretch max-[900px]:grid-cols-1 max-[900px]:gap-8"
    >
      {
        flow.map((f, i) => (
          <>
            {/* z-10 + opaque card fill so the pen head and its ink tail run
                BEHIND the cards and tuck under their edges */}
            <div class="relative z-10">
              <div
                class:list={[
                  'relative border-[1.5px] border-rule bg-bg px-7 pb-6 pt-[26px]',
                  f.build && 'hatch border-2 border-acc',
                ]}
              >
                <div class="absolute -top-[19px] left-0 font-mono text-[11px] text-soft">0{i + 1}</div>
                <div
                  class:list={[
                    'mb-2.5 text-[25px] italic leading-none',
                    f.build ? 'font-semibold text-acc' : 'text-ink',
                  ]}
                >
                  {f.label}
                </div>
                <div class="font-mono text-[12px] leading-[1.5] text-mut">{f.ann}</div>
              </div>
              <p class="mx-1 mb-0 mt-[22px] text-[15px] leading-[1.55] text-mut">
                <strong class="font-semibold text-ink">{f.lead}</strong> {f.desc}
              </p>
            </div>
            {i < flow.length - 1 && (
              <div class="conn flow-conn mt-[58px] self-start max-[900px]:hidden">
                <span class="conn-arrow" aria-hidden="true" />
                <span class="conn-packet" aria-hidden="true" />
              </div>
            )}
          </>
        ))
      }
    </div>
    <figcaption class="mt-11 flex items-baseline gap-4 border-t border-line pt-4">
      <span class="font-mono text-[11.5px] text-acc">fig. 01</span>
      <span class="font-mono text-[12.5px] not-italic text-mut"
        >the system, sketched before the code — drawn first, then built</span
      >
    </figcaption>
  </figure>
  <div class="pt-[26px] font-mono text-[12px] text-soft">
    founder of <b class="font-medium text-mut">tiny edges</b> · kuala lumpur, malaysia · works in production: {
      work.filter((w) => w.data.status !== 'closed').length
    }
  </div>

  <!-- fig. 02 — what this usually looks like -->
  <section class={secWrap}>
    <SectionHead
      fig="02"
      title="What this usually"
      em="looks like"
      sub="four shapes the same conversation tends to take."
    />
    <div class="grid grid-cols-2 gap-x-[72px] max-[760px]:grid-cols-1" data-stagger>
      {
        cases.map(([id, h, p]) => (
          <div class="grid grid-cols-[78px_1fr] gap-[18px] border-b border-line py-[26px] max-[560px]:grid-cols-1 max-[560px]:gap-2">
            <div class="pt-1.5 font-mono text-[12px] text-soft max-[560px]:pt-0">case {id} /</div>
            <div>
              <h3 class="mb-2 mt-0 text-[21.5px] font-semibold leading-[1.3] text-ink">{h}</h3>
              <p class="m-0 text-[15.5px] text-mut">{p}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- fig. 03 — about -->
  <section class={secWrap} id="about">
    <SectionHead fig="03" title="The short" em="version" />
    <div
      class="mt-2.5 grid grid-cols-[1fr_300px] items-start gap-20 max-[900px]:grid-cols-1 max-[900px]:gap-9"
      data-stagger
    >
      <div>
        <p class="mb-5 mt-0 text-[19px] leading-[1.62] text-ink">
          I started as an engineer, then spent a decade as the person responsible for turning ideas into working
          systems.
        </p>
        <p class="mb-5 text-[19px] leading-[1.62] text-ink">
          Over time, I moved from writing code to leading technical work, helping scale a company from a small team of
          around ten people to about a hundred. That experience shaped how I see software: good software is not just
          clean code. It is a system that fits the business, the people, the timing, the constraints, and the next stage
          of growth.
        </p>
        <p class="mb-0 text-[19px] leading-[1.62] text-ink">
          Today I run Tiny Edges. I work with founders and SMEs to shape and build the software their business needs
          next. Sometimes it is a straightforward build. Sometimes, when the opportunity is strong and the fit is right,
          I work closer to the outcome through a stake, revenue share, or longer-term partnership.
        </p>
      </div>
      <aside class="relative border border-rule bg-bg p-3.5 max-[900px]:max-w-[300px]">
        <Ticks />
        <img
          src="/woo-kin-wai-software-builder.avif"
          alt="Woo Kin Wai, software builder and technical partner"
          width="1500"
          height="1497"
          loading="lazy"
          decoding="async"
          class="block w-full saturate-[.9] contrast-[1.02]"
        />
        <div class="flex justify-between px-0.5 pb-0.5 pt-3 font-mono text-[11px] text-mut">
          <span>woo kin wai</span>
          <span>kuala lumpur</span>
        </div>
      </aside>
    </div>
    <div
      class="relative mt-[72px] flex items-baseline gap-10 border border-rule bg-bg px-14 py-12 max-[760px]:flex-col max-[760px]:gap-4 max-[760px]:px-7 max-[760px]:py-9"
    >
      <Ticks />
      <span class="whitespace-nowrap font-mono text-[12px] text-acc">the working question /</span>
      <blockquote class="m-0 text-[clamp(23px,3vw,31px)] font-medium italic leading-[1.35] text-ink">
        What system does this business need in order to grow?
      </blockquote>
    </div>
  </section>

  <!-- fig. 04 — selected work: the build sheets -->
  <section class={secWrap} id="work">
    <SectionHead
      fig="04"
      title="Selected"
      em="work"
      sub="as of may 2026. a few examples of growth needs turned into working systems, from founder-led products to platforms and internal tools."
    />
    {
      work.length === 0 && (
        <p class="mt-3 border-b border-line pb-5 font-mono text-[12px] text-soft">selected work will appear here.</p>
      )
    }
    {
      work.map((entry, i) => {
        const w = entry.data;
        const closed = w.status === 'closed';
        const hasShot = Boolean(w.screenshotUrl || w.shot);
        const modelBits = [w.engagement && modelLabel[w.engagement], w.role?.toLowerCase()].filter(Boolean);
        return (
          <article
            class:list={['mt-12 border bg-bg first-of-type:mt-3', closed ? 'border-dashed border-mut' : 'border-rule']}
          >
            <div
              class:list={[
                'grid grid-cols-[120px_1fr_auto] border-b max-[900px]:grid-cols-1',
                closed ? 'border-dashed border-line' : 'border-rule',
              ]}
            >
              <div class="flex items-center border-r border-line px-[22px] py-4 font-mono text-[11.5px] text-soft max-[900px]:border-r-0 max-[900px]:border-b max-[900px]:border-line max-[900px]:py-2.5">
                sheet 04.{i + 1}
              </div>
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 px-[22px] py-4">
                <h3 class="m-0 whitespace-nowrap text-[27px] font-semibold text-ink">{w.name}</h3>
                <span class="text-[16px] italic text-mut">{w.tease}</span>
              </div>
              <div class="flex items-center gap-3.5 border-l border-line px-[22px] py-4 font-mono text-[11.5px] text-mut max-[900px]:border-l-0 max-[900px]:border-t max-[900px]:border-line max-[900px]:py-2.5">
                <span class="flex items-center gap-1.5 whitespace-nowrap">
                  <span class:list={['smark', w.status]} />
                  {statusLabel[w.status]}
                </span>
                {modelBits.length > 0 && <span class="text-acc">{modelBits.join(' · ')}</span>}
              </div>
            </div>
            <div class:list={['grid max-[900px]:grid-cols-1', hasShot ? 'grid-cols-[1.15fr_1fr]' : 'grid-cols-2']}>
              <div class="border-r border-line p-[30px_34px_34px] max-[900px]:border-r-0 max-[900px]:border-b max-[900px]:border-line max-[900px]:p-6">
                {hasShot ? (
                  <div>
                    <div class="border border-rule">
                      {w.screenshotUrl ? (
                        <img
                          src={w.screenshotUrl}
                          alt={w.shot?.label || `${w.name} screenshot`}
                          loading="lazy"
                          decoding="async"
                          class="block aspect-[16/10] w-full object-cover object-top"
                        />
                      ) : (
                        <div class="grid aspect-[16/10] place-items-center bg-[repeating-linear-gradient(-45deg,var(--color-acc-soft)_0_5px,transparent_5px_11px)]">
                          <span class="border border-line bg-bg px-3 py-1.5 font-mono text-[10.5px] text-soft">
                            {w.name.toLowerCase()} — drawing to follow
                          </span>
                        </div>
                      )}
                    </div>
                    {w.shot && (
                      <div class="flex flex-wrap justify-between gap-x-4 gap-y-1 px-0.5 pt-3 font-mono text-[11px] text-mut">
                        <span>{w.shot.label}</span>
                        <span>{w.shot.url} ↗</span>
                      </div>
                    )}
                  </div>
                ) : (
                  w.bodyHtml && (
                    <p class="m-0 text-[16.5px] leading-[1.58] text-ink [&_b]:font-semibold" set:html={w.bodyHtml} />
                  )
                )}
              </div>
              <div class="p-[30px_34px_34px] max-[900px]:p-6">
                {hasShot && w.bodyHtml && (
                  <p
                    class="mb-[22px] mt-0 text-[16.5px] leading-[1.58] text-ink [&_b]:font-semibold"
                    set:html={w.bodyHtml}
                  />
                )}
                {w.stack.length > 0 && (
                  <div class="mb-5 font-mono text-[11.5px] text-mut">
                    <span class="text-soft">stack /</span> {w.stack.map((s) => s.toLowerCase()).join(' · ')}
                  </div>
                )}
                {w.nd.length > 0 && (
                  <dl class="m-0 border-t border-line">
                    {w.nd.map((n) => (
                      <div class={factRow}>
                        <dt class={factKey}>{n.label.toLowerCase()}</dt>
                        <dd class={factVal}>{n.text}</dd>
                      </div>
                    ))}
                  </dl>
                )}
                {w.visit && (
                  <a
                    href={w.visit.href}
                    target="_blank"
                    rel="noopener"
                    class="mt-6 inline-block border-b border-acc pb-0.5 font-mono text-[12.5px] text-acc no-underline transition-colors hover:border-acc-2 hover:text-acc-2"
                  >
                    {w.visit.label.toLowerCase()} →
                  </a>
                )}
              </div>
            </div>
          </article>
        );
      })
    }
  </section>

  <!-- fig. 05 — how the work unfolds -->
  <section class={secWrap} id="process">
    <SectionHead fig="05" title="How the work" em="unfolds" sub="small, serious versions. then iteration." />
    <div class="tl-line mx-[30px] mt-[70px] max-[760px]:hidden">
      <span class="conn-arrow" aria-hidden="true"></span>
      <span class="conn-packet" aria-hidden="true"></span>
    </div>
    <div
      class="tl-stops mx-[30px] grid grid-cols-4 max-[760px]:mx-0 max-[760px]:grid-cols-1 max-[760px]:gap-9"
      data-stagger
    >
      {
        steps.map(([id, h, p], i) => (
          <div class:list={['tl-stop relative pr-9 pt-[30px] max-[760px]:pt-0', i === steps.length - 1 && 'is-last']}>
            <span class="tl-mark max-[760px]:hidden" aria-hidden="true" />
            <div class="mb-3 font-mono text-[11.5px] text-soft">step {id} /</div>
            <h3 class="mb-2 mt-0 text-[21px] font-semibold italic text-ink">{h}</h3>
            <p class="m-0 text-[15px] text-mut">{p}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- contact — the title block -->
  <section class="reveal pb-12 pt-[110px] max-[760px]:pt-20" id="contact">
    <p
      class="mx-auto mb-14 max-w-[760px] text-balance text-center text-[clamp(26px,3.6vw,40px)] font-semibold leading-[1.25] tracking-[-0.01em] text-ink"
    >
      If you can describe where your business is trying to grow,
      <em class="font-medium italic text-acc">I can help you work out the system it needs.</em>
    </p>
    <div class="relative mx-auto max-w-[820px] border-[1.5px] border-rule bg-bg">
      <Ticks />
      <div class="grid grid-cols-[200px_1fr] border-b border-line max-[560px]:grid-cols-1">
        <div
          class="flex items-center border-r border-line px-[22px] py-[15px] font-mono text-[11.5px] text-soft max-[560px]:border-r-0 max-[560px]:pb-0"
        >
          project /
        </div>
        <div class="px-[22px] py-[15px] text-[16px] text-ink">the system your business needs next</div>
      </div>
      <div class="grid grid-cols-[200px_1fr] border-b border-line max-[560px]:grid-cols-1">
        <div
          class="flex items-center border-r border-line px-[22px] py-[15px] font-mono text-[11.5px] text-soft max-[560px]:border-r-0 max-[560px]:pb-0"
        >
          drawn by /
        </div>
        <div class="px-[22px] py-[15px] text-[16px] text-ink">{SITE.author} — {SITE.org}</div>
      </div>
      <div class="grid grid-cols-[200px_1fr] border-b border-line max-[560px]:grid-cols-1">
        <div
          class="flex items-center border-r border-line px-[22px] py-[15px] font-mono text-[11.5px] text-soft max-[560px]:border-r-0 max-[560px]:pb-0"
        >
          location /
        </div>
        <div class="px-[22px] py-[15px] font-mono text-[13px] text-mut">kuala lumpur · gmt+8</div>
      </div>
      <div class="grid grid-cols-[200px_1fr] max-[560px]:grid-cols-1">
        <div
          class="flex items-center border-r border-line px-[22px] py-[15px] font-mono text-[11.5px] text-soft max-[560px]:border-r-0 max-[560px]:pb-0"
        >
          contact /
        </div>
        <div class="px-[22px] py-[22px]"><EmailButton /></div>
      </div>
    </div>
    <p class="mt-7 text-center font-mono text-[12px] text-soft">
      <a href="/contact" class="text-soft no-underline transition-colors hover:text-acc"
        >what to expect, fit, and faq — on the contact page&nbsp;→</a
      >
    </p>
  </section>
</BaseLayout>

<script>
  // Relays, ported from the previous design and redrawn in drafting language.
  //
  // fig. 01 — growth → gap → build: an anime.js timeline sends a green "pen
  // head" down each dashed leader line in turn; the arrowhead pulses as it
  // arrives. The packet is the work moving through the system.
  //
  // fig. 05 — the drafted timeline: the same pen head travels the baseline
  // stop to stop, and each square marker pulses as the work passes through it
  // (listen → shape → build → stay close), fading out at the arrowhead.
  //
  // The other sections stay still on purpose: cases, sheets, and the title
  // block have no direction to animate — motion there would be noise. Both
  // relays run only while on screen, skip entirely under reduced motion, and
  // rebind cleanly across View-Transition navigations.
  import { createTimeline } from 'animejs';

  const STEP = 720; // fig. 01 — travel time per leader line
  const WALK = 1400; // fig. 05 — travel time per baseline segment (a slower, surveying pace)
  const OVERLAP = 100; // how much the next segment fires before the last lands
  const DWELL = 660; // pause between loops

  let tls: ReturnType<typeof createTimeline>[] = [];
  let ios: IntersectionObserver[] = [];

  function teardown() {
    ios.forEach((io) => io.disconnect());
    ios = [];
    tls.forEach((tl) => {
      tl.pause();
      tl.revert();
    });
    tls = [];
  }

  // play/pause a timeline as its host scrolls in and out of view
  function bind(watch: HTMLElement, tl: ReturnType<typeof createTimeline>) {
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => (e.isIntersecting ? tl.play() : tl.pause())),
      { threshold: 0.25 }
    );
    io.observe(watch);
    ios.push(io);
    tls.push(tl);
  }

  const visible = (el: HTMLElement | null): el is HTMLElement => !!el && el.getClientRects().length > 0;

  function initRelays() {
    teardown();
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // fig. 01 — leader-line relay
    const flow = document.querySelector<HTMLElement>('.flow-relay');
    const conns = flow ? [...flow.querySelectorAll<HTMLElement>('.flow-conn')].filter(visible) : [];
    if (flow && conns.length) {
      flow.classList.add('flow-live');
      const tl = createTimeline({ loop: true, autoplay: false, defaults: { ease: 'inOutQuad' } });
      let at = 0;
      conns.forEach((conn) => {
        const packet = conn.querySelector<HTMLElement>('.conn-packet');
        const arrow = conn.querySelector<HTMLElement>('.conn-arrow');
        if (!packet) return;
        tl.add(
          packet,
          {
            left: ['0%', '100%'],
            // fade in fast, ride the line lit, snuff out on arrival
            opacity: [
              { to: 1, duration: 70 },
              { to: 1, duration: 560 },
              { to: 0, duration: 90 },
            ],
            duration: STEP,
          },
          at
        );
        if (arrow) {
          tl.add(
            arrow,
            { scale: [1, 1.5, 1], opacity: [0.55, 1, 0.55], duration: 340, ease: 'outQuad' },
            at + STEP - 190
          );
        }
        at += STEP - OVERLAP;
      });
      // hold on the empty line before the relay loops
      const first = conns[0].querySelector<HTMLElement>('.conn-packet');
      if (first) tl.add(first, { opacity: 0, duration: DWELL }, at);
      bind(flow, tl);
    }

    // fig. 05 — baseline walk: stop to stop, pulsing each marker on arrival
    const line = document.querySelector<HTMLElement>('.tl-line');
    const stops = document.querySelector<HTMLElement>('.tl-stops');
    const packet = line?.querySelector<HTMLElement>('.conn-packet');
    const arrow = line?.querySelector<HTMLElement>('.conn-arrow');
    const marks = stops ? [...stops.querySelectorAll<HTMLElement>('.tl-mark')] : [];
    if (visible(line) && packet && stops && marks.length === 4) {
      line.classList.add('flow-live');
      const tl = createTimeline({ loop: true, autoplay: false, defaults: { ease: 'inOutQuad' } });
      let at = 0;
      // set off from the first stop…
      tl.add(marks[0], { scale: [1, 1.4, 1], duration: 300, ease: 'outQuad' }, 0);
      tl.add(packet, { opacity: [0, 1], duration: 90 }, 0);
      // …walk the three segments between the four stops…
      for (let k = 0; k < 3; k++) {
        tl.add(packet, { left: [`${k * 25}%`, `${(k + 1) * 25}%`], duration: WALK }, at);
        tl.add(marks[k + 1], { scale: [1, 1.4, 1], duration: 360, ease: 'outQuad' }, at + WALK - 200);
        at += WALK - OVERLAP;
      }
      // …then run off the end of the drawing
      tl.add(
        packet,
        {
          left: ['75%', '100%'],
          opacity: [
            { to: 1, duration: WALK - 120 },
            { to: 0, duration: 120 },
          ],
          duration: WALK,
        },
        at
      );
      if (arrow) {
        tl.add(
          arrow,
          { scale: [1, 1.5, 1], opacity: [0.55, 1, 0.55], duration: 380, ease: 'outQuad' },
          at + WALK - 230
        );
      }
      tl.add(packet, { opacity: 0, duration: DWELL }, at + WALK);
      bind(stops, tl);
    }
  }

  document.addEventListener('astro:page-load', initRelays);
  document.addEventListener('astro:before-swap', teardown);
</script>
