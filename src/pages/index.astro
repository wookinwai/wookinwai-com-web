---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import EmailButton from '../components/EmailButton.astro';
import { getCollection } from 'astro:content';

const title = 'Woo Kin Wai: software builder & technical partner';
const description =
  'I work with founders and SMEs to shape and build the software their business needs next, from products to platforms to internal tools. Founder of Tiny Edges, Kuala Lumpur.';

// Selected work — CMS-driven (section 03).
const work = (await getCollection('work')).sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const statusLabel = { live: 'Live', building: 'Building', ongoing: 'Ongoing', closed: 'Closed' } as const;
// Literal class strings (not `text-${status}`) so Tailwind actually generates
// these utilities. Note: 'building' maps to text-build (the --color-build token).
const statusColor = { live: 'text-live', building: 'text-build', ongoing: 'text-ongoing', closed: 'text-closed' } as const;
// Engagement → "Model" cell. Cobalt (acc-blue) is the one sanctioned categorical
// secondary: build engagements vs red upside participation.
const modelMap = {
  upside: { value: 'Upside participation', tone: 'acc' },
  engaged: { value: 'Engaged to build', tone: 'blue' },
} as const;

const flow = [
  {
    n: '01',
    label: 'The growth',
    title: 'Where the business wants to go',
    desc: 'New revenue, better operations, a product idea, a platform, or a market opportunity that is starting to become real.',
  },
  {
    n: '02',
    label: 'The gap',
    title: 'The system is missing',
    desc: 'The work is still manual, scattered, unclear, or technically fragile. The ambition exists, but the operating shape does not.',
  },
  {
    n: '03',
    label: 'The build',
    title: 'Software that can carry it',
    desc: 'A product, platform, portal, internal tool, workflow, or technical foundation designed around how the business actually works.',
    build: true,
  },
];

const scenarios = [
  ['New product', 'A new product has to become real', 'A founder sees the opportunity, but the first serious version still needs to be shaped, scoped, architected, and built.'],
  ['Operations', 'Operations have outgrown the workaround', 'The business runs on spreadsheets, WhatsApp, manual checks, duplicated effort, and knowledge that lives in people’s heads.'],
  ['Platform', 'A platform needs technical direction', 'The idea is bigger than a simple website. It needs a backend, data model, workflows, integrations, and decisions that will hold up later.'],
  ['Partnership', 'The business needs a technical partner', 'Not just someone to take tickets, but someone who can understand the business, make tradeoffs, and stay close to the outcome.'],
];

const steps = [
  ['01', 'Listen', 'Understand where the business wants to grow, what is blocking it, and what cannot be ignored. Get this wrong and everything built on top of it is wrong too.'],
  ['02', 'Shape', 'Turn the ambition into a clear product, workflow, platform, or system design. Decide what to build before deciding how to build it.'],
  ['03', 'Build', 'Create the smallest serious version that can be used and improved. AI moves fast on the routine parts so the time goes where judgement is needed.'],
  ['04', 'Improve', 'Work with my team at Tiny Edges to build on it, using what real use reveals. The first version is the start of the work, not the end of it.'],
  ['05', 'Stay close', 'Ship, learn, adjust. Where I share in the upside, I stay close to the outcome.'],
];

// shared section spacing (the masthead itself lives in <SectionHead/>)
const secWrap = 'reveal pt-[112px] max-[760px]:pt-[84px]';
const lead = 'mt-[26px] text-[17px] leading-[1.66] text-mut';

const ndLabel = 'whitespace-nowrap border-r-2 border-rule px-4 py-[13px] font-mono text-[9.5px] font-bold uppercase tracking-[0.13em] text-soft';
const ndText = 'px-4 py-[13px] text-[15px] leading-[1.4] text-ink';
const metaLabel = 'font-mono text-[9.5px] font-bold uppercase tracking-[0.13em] text-soft';
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <header class="pt-[84px]">
    <div class="rise d1 flex flex-col gap-1.5 font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-acc">
      <span>Software builder and technical partner</span><span class="text-soft">Founder of Tiny Edges · Kuala Lumpur, Malaysia</span>
    </div>
    <h1
      class="rise d2 mt-6 max-w-[1000px] text-balance font-sans text-[clamp(32px,5.4vw,62px)] font-extrabold leading-[1.05] tracking-[-0.03em] text-ink"
    >
      I help businesses define and build the software they need for their
      <span class="text-acc">next stage of growth</span>.
    </h1>
    <p class="rise d3 mt-[26px] max-w-[620px] text-[17px] leading-[1.6] text-mut">
      The work usually starts before the code: where the business is trying to go, what is getting in the way, and
      what kind of system would actually help it move.
    </p>
    <p class="rise d3 mt-[18px] max-w-[620px] text-[17px] leading-[1.6] text-mut">
      Sometimes that means building a product from zero. Sometimes it means turning messy operations into software.
      Sometimes it means helping a founder shape the technical path before the first serious build.
    </p>
    <a
      href="#work"
      class="rise d3 mt-7 inline-flex items-center gap-2 pb-[3px] font-mono text-[11.5px] font-bold uppercase tracking-[0.12em] text-ink no-underline shadow-[inset_0_-2px_0_var(--color-acc)] transition-all hover:gap-3"
      >See selected work ↓</a
    >

    <!-- growth → gap → build flow -->
    <div class="flow-relay rise d4 mt-14 flex items-stretch max-[760px]:flex-col max-[760px]:gap-3">
      {
        flow.map((f, i) => (
          <>
            <div
              class:list={[
                // z-10 + opaque fill so the connector packet/comet runs BEHIND the
                // cards and tucks under their edges instead of bleeding over them.
                'relative z-10 flex-1 overflow-hidden rounded-[2px] border-2 px-[22px] pb-6 pt-[22px] transition-all',
                f.build
                  ? 'border-acc bg-acc text-on-accent hover:-translate-y-0.5 hover:shadow-sm'
                  : 'border-rule bg-bg hover:-translate-y-0.5 hover:bg-panel hover:shadow-sm',
              ]}
            >
              <div class="flex items-baseline justify-between">
                <div class:list={['font-mono text-[10px] font-bold uppercase tracking-[0.18em]', f.build ? 'text-on-accent' : 'text-acc']}>{f.label}</div>
                <div class:list={['font-mono text-[11px] font-bold', f.build ? 'text-on-accent' : 'text-soft']}>{f.n}</div>
              </div>
              <div class:list={['mb-2.5 mt-3 font-sans text-[19px] font-extrabold leading-[1.1] tracking-[-0.02em]', f.build ? 'text-on-accent' : 'text-ink']}>{f.title}</div>
              <div class:list={['text-[13.5px] leading-[1.55]', f.build ? 'text-on-accent' : 'text-mut']}>{f.desc}</div>
            </div>
            {i < flow.length - 1 && (
              <div class="flow-conn relative flex flex-[0_0_64px] items-center self-center px-[5px] max-[760px]:hidden">
                <span class="absolute left-px top-1/2 z-[2] -mt-[3px] h-1.5 w-1.5 bg-acc" />
                <div class="relative h-[2px] w-full bg-line">
                  <span class="flow-packet absolute left-0 top-1/2 z-[3] -mt-[3px] h-1.5 w-1.5 bg-acc opacity-0" />
                </div>
                <svg width="11" height="11" viewBox="0 0 11 11" class="flow-arrow absolute -right-px text-acc" aria-hidden="true">
                  <path d="M1.5 5.5h6M5.5 2.5l3 3-3 3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
            )}
          </>
        ))
      }
    </div>
  </header>

  <!-- 01 — The pattern -->
  <section class={secWrap}>
    <SectionHead
      index="01 / The pattern"
      title="What this usually looks like"
      sub="Growth exposes the systems a business does not have yet."
    >
    <p class={lead}>
      The work often starts before the code. The first question is not which stack to use. It is what kind of system the
      business needs in order to move.
    </p>
    <div class="mt-[34px] grid grid-cols-2 overflow-hidden rounded-[2px] border-2 border-rule max-[760px]:grid-cols-1">
      {
        scenarios.map(([cat, h, p], i) => (
          <div class:list={[i % 2 === 1 && 'border-l-2 border-rule max-[760px]:border-l-0', i >= 2 && 'border-t-2 border-rule', 'max-[760px]:border-t-2 max-[760px]:[&:first-child]:border-t-0']}>
            <div class="group h-full bg-transparent p-[28px_26px] text-ink transition-colors hover:bg-ink hover:text-on-ink">
              <div class="mb-3 flex items-center gap-[9px]">
                <span class="h-[7px] w-[7px] flex-none bg-acc" />
                <span class="font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-mut transition-colors group-hover:text-on-ink">{cat}</span>
              </div>
              <h3 class="mb-2.5 font-sans text-[20px] font-extrabold leading-[1.08] tracking-[-0.02em]">{h}</h3>
              <p class="m-0 text-[14px] leading-[1.58] text-mut transition-colors group-hover:text-on-ink">{p}</p>
            </div>
          </div>
        ))
      }
    </div>
    </SectionHead>
  </section>

  <!-- 02 — About -->
  <section class={secWrap} id="about">
    <SectionHead index="02 / About" title="The short version">
      <aside slot="rail" class="mt-5 max-[760px]:max-w-[200px]">
        <div class="aspect-[4/5] overflow-hidden rounded-[2px] border-2 border-rule bg-panel shadow-card">
          <img
            src="/woo-kin-wai-software-builder.avif"
            alt="Woo Kin Wai, software builder and technical partner"
            width="1500"
            height="1497"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </div>
      </aside>
      <div class="mt-[30px] text-[17px] leading-[1.7] text-ink" data-stagger>
        <p class="mb-4">
          I trained as an engineer, then spent about a decade building software, mostly client work at an agency and some
          outsourced projects. Over that time I moved into technical leadership and helped grow the company from around
          <b class="font-bold">10 people to about 100</b>. That experience shaped how I see software.
        </p>
        <p class="mb-4">
          Good software is not just clean code. It is a system that fits the business, the people, the timing, the
          constraints, and the next stage of growth.
        </p>
        <p class="mb-4">
          AI changes how fast software gets built, not what makes it worth building. The hard part is still deciding
          what the business actually needs.
        </p>
        <p class="mb-4">
          Today I run <a href="https://www.tinyedges.com/" target="_blank" rel="noopener" class="font-bold text-ink underline decoration-acc decoration-2 underline-offset-[3px] transition-colors hover:text-acc">Tiny Edges</a>. I work with founders and SMEs to shape and build the
          software their business needs next.
        </p>
        <p class="mb-4">
          Most of the work is a direct build on a fee. Sometimes, when the opportunity is strong and the fit is right, I
          work closer to the outcome through a <b class="font-bold text-acc">stake, revenue share, or a longer-term partnership</b>.
        </p>
        <blockquote
          class="my-[30px] border-l-4 border-acc pl-[22px] font-sans text-[clamp(24px,3.2vw,34px)] font-extrabold leading-[1.12] tracking-[-0.025em] text-ink"
        >
          What system does this business need in order to grow?
        </blockquote>
        <div class="mt-[26px] flex items-center gap-[14px]">
          <div class="grid h-12 w-12 flex-none place-items-center rounded-[2px] border-2 border-rule bg-panel font-mono text-[13px] font-bold text-ink">
            WKW
          </div>
          <div class="font-sans text-[18px] font-extrabold tracking-[-0.015em] text-ink">
            Kin Wai<small class="mt-1 block font-mono text-[10px] font-medium uppercase tracking-[0.12em] text-soft">Kuala Lumpur</small>
          </div>
        </div>
      </div>
    </SectionHead>
  </section>

  <!-- 03 — Selected work -->
  <section class={secWrap} id="work">
    <SectionHead index="03 / Selected work" title="Selected work" sub="As of May 2026">
    <p class={lead}>
      A few examples of growth needs turned into working systems, from founder-led products to platforms and internal
      tools.
    </p>

    <div class="mt-[30px] border-t-2 border-rule" data-stagger>
      {work.length === 0 && (
        <p class="border-b-2 border-rule py-5 font-mono text-[12px] uppercase tracking-[0.12em] text-soft">
          Selected work will appear here.
        </p>
      )}
      {
        work.map((entry, i) => {
          const w = entry.data;
          const model = w.engagement ? modelMap[w.engagement] : null;
          return (
            <div class="flow border-b-2 border-rule">
              <div class="flow-main row-edge group grid cursor-pointer grid-cols-[auto_1fr_auto] items-center gap-[18px] py-5 transition-colors hover:bg-panel max-[760px]:grid-cols-[auto_1fr]">
                <div class="w-7 font-mono text-[13px] font-bold text-acc">{String(i + 1).padStart(2, '0')}</div>
                <div>
                  <div class="flex items-center gap-3 font-sans text-[23px] font-extrabold tracking-[-0.015em] text-ink transition-colors group-hover:text-acc">
                    {w.name}
                    <span class="exp inline-block font-mono text-[15px] font-bold text-acc">+</span>
                  </div>
                  <div class="mt-1 text-[14px] text-mut">{w.tease}</div>
                </div>
                <div class:list={['flex items-center gap-2 whitespace-nowrap font-mono text-[10.5px] font-bold uppercase tracking-[0.16em] max-[760px]:col-span-2 max-[760px]:pl-[34px]', statusColor[w.status]]}>
                  <span class:list={['smark', w.status]} />
                  {statusLabel[w.status]}
                </div>
              </div>
              <div class="detail">
                <div class="pb-9 pt-1.5">
                  {(w.shot || w.screenshotUrl) && (
                    <div class="mb-6 aspect-[16/9] overflow-hidden rounded-[2px] border-2 border-rule bg-panel shadow-card">
                      <div class="flex h-[30px] items-center gap-1.5 border-b-2 border-rule bg-bg px-3">
                        <i class="block h-2 w-2 bg-rule" />
                        <i class="block h-2 w-2 bg-rule" />
                        <i class="block h-2 w-2 bg-rule" />
                        <span class="ml-[9px] font-mono text-[9.5px] font-medium text-soft">{w.shot?.url}</span>
                      </div>
                      {w.screenshotUrl ? (
                        <img
                          src={w.screenshotUrl}
                          alt={w.shot?.label || `${w.name} screenshot`}
                          loading="lazy"
                          decoding="async"
                          class="h-[calc(100%-30px)] w-full object-cover object-top"
                        />
                      ) : (
                        <div
                          class="grid h-[calc(100%-30px)] place-items-center"
                          style="background:repeating-linear-gradient(45deg, transparent, transparent 11px, var(--color-line-2) 11px, var(--color-line-2) 12px);"
                        >
                          <span class="border-2 border-rule bg-panel px-3 py-1.5 font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-soft">
                            {w.name} screenshot
                          </span>
                        </div>
                      )}
                    </div>
                  )}
                  <div class="mb-6 grid grid-cols-[auto_1fr] overflow-hidden rounded-[2px] border-2 border-rule">
                    {w.nd.map((n, j) => (
                      <>
                        <span class:list={[ndLabel, j > 0 && 'border-t border-line']}>{n.label}</span>
                        <span class:list={[ndText, j > 0 && 'border-t border-line']}>{n.text}</span>
                      </>
                    ))}
                  </div>
                  {(w.role || model) && (
                    <div class="mb-5 flex w-fit flex-wrap overflow-hidden rounded-[2px] border-2 border-rule">
                      {w.role && (
                        <div class="flex flex-col gap-1 px-[18px] py-3">
                          <span class={metaLabel}>Role</span>
                          <span class="font-mono text-[13px] font-medium text-ink">{w.role}</span>
                        </div>
                      )}
                      {model && (
                        <div class="flex flex-col gap-1 border-l-2 border-rule px-[18px] py-3">
                          <span class={metaLabel}>Model</span>
                          <span class:list={['inline-flex items-center gap-[7px] font-mono text-[13px] font-medium', model.tone === 'acc' ? 'text-acc' : 'text-acc-blue']}>
                            <span class:list={['h-1.5 w-1.5 flex-none', model.tone === 'acc' ? 'bg-acc' : 'bg-acc-blue']} />
                            {model.value}
                          </span>
                        </div>
                      )}
                    </div>
                  )}
                  {w.bodyHtml && (
                    <p class="mb-[18px] text-[16px] leading-[1.66] text-mut [&_b]:font-bold [&_b]:text-ink" set:html={w.bodyHtml} />
                  )}
                  {w.stack.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {w.stack.map((s) => (
                        <span class="border-2 border-rule px-[10px] py-[5px] font-mono text-[10.5px] uppercase leading-none tracking-[0.08em] text-mut">{s}</span>
                      ))}
                    </div>
                  )}
                  {w.visit && (
                    <a
                      href={w.visit.href}
                      target="_blank"
                      rel="noopener"
                      class="mt-5 inline-flex items-center rounded-[2px] border-2 border-acc px-4 py-2.5 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-acc no-underline transition-all hover:-translate-x-px hover:-translate-y-px hover:bg-acc hover:text-on-accent hover:shadow-acc"
                    >
                      {w.visit.label}
                    </a>
                  )}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
    </SectionHead>
  </section>

  <!-- 04 — Process -->
  <section class={secWrap} id="process">
    <SectionHead
      index="04 / Process"
      title="How the work happens"
      sub="The same loop, adjusted to the business."
    >
    <p class={lead}>
      The process is deliberately simple. Get the problem right, build the smallest serious version that works, then keep
      improving it with my team as real use shows what matters.
    </p>
    <ol class="proc mt-[42px]" data-proc>
      {
        steps.map(([num, h, p], i) => (
          <li class="proc-step group" style={`--i:${i}`}>
            <div class="proc-rail">
              <span class="proc-num">{num}</span>
              <span class="proc-node" />
              {i < steps.length - 1 && <span class="proc-line" />}
            </div>
            <div class="proc-body">
              <h3 class="proc-title">{h}</h3>
              <p class="proc-desc">{p}</p>
            </div>
          </li>
        ))
      }
    </ol>
    </SectionHead>
  </section>

  <!-- 05 — Contact -->
  <section class={secWrap} id="contact">
    <SectionHead
      index="05 / Contact"
      title="When it makes sense to talk"
      sub="You have a real growth problem, and the system matters."
    >
    <p class={lead}>
      I am especially interested in founder-led businesses, SMEs, and early ventures where the opportunity is practical,
      the constraints are real, and the technical work has to connect back to the business.
    </p>
    <a
      href="/contact"
      class="mt-7 inline-flex items-center gap-2 font-mono text-[11.5px] font-bold uppercase tracking-[0.12em] text-ink no-underline shadow-[inset_0_-2px_0_var(--color-acc)] transition-all hover:gap-3"
      >See if it's a fit, what to expect, and FAQ → Contact</a
    >
    <div class="mt-10"><EmailButton /></div>
    </SectionHead>
  </section>
</BaseLayout>

<script>
  // growth → gap → build: an anime.js timeline relays a red signal packet down
  // each connector wire (Growth → Gap → Build), looping with a brief dwell. Runs
  // only while the flow is on screen, skips entirely under reduced-motion, and
  // rebinds cleanly across View-Transition navigations.
  import { createTimeline } from 'animejs';

  let tl: ReturnType<typeof createTimeline> | null = null;
  let io: IntersectionObserver | null = null;

  function teardown() {
    io?.disconnect();
    io = null;
    tl?.pause();
    tl?.revert();
    tl = null;
  }

  function initFlow() {
    teardown();

    const flow = document.querySelector<HTMLElement>('.flow-relay');
    if (!flow) return;
    const conns = [...flow.querySelectorAll<HTMLElement>('.flow-conn')];
    if (!conns.length) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    flow.classList.add('flow-live');

    tl = createTimeline({ loop: true, autoplay: false, defaults: { ease: 'inOutQuad' } });

    const STEP = 720; // packet travel time per wire
    const OVERLAP = 100; // how much the next wire fires before the last lands
    const DWELL = 660; // pause between loops
    let at = 0;

    conns.forEach((conn) => {
      const packet = conn.querySelector<HTMLElement>('.flow-packet');
      const arrow = conn.querySelector<SVGElement>('.flow-arrow');
      if (!packet) return;

      tl!.add(
        packet,
        {
          left: ['0%', '100%'],
          // fade in fast, ride the wire lit, snuff out on arrival
          opacity: [{ to: 1, duration: 70 }, { to: 1, duration: 560 }, { to: 0, duration: 90 }],
          duration: STEP,
        },
        at
      );

      if (arrow) {
        tl!.add(
          arrow,
          { scale: [1, 1.5, 1], opacity: [0.5, 1, 0.5], duration: 340, ease: 'outQuad' },
          at + STEP - 190
        );
      }

      at += STEP - OVERLAP;
    });

    // hold on the empty wire before the relay loops
    const first = conns[0].querySelector<HTMLElement>('.flow-packet');
    if (first) tl.add(first, { opacity: 0, duration: DWELL }, at);

    io = new IntersectionObserver(
      (entries) => entries.forEach((e) => (e.isIntersecting ? tl?.play() : tl?.pause())),
      { threshold: 0.25 }
    );
    io.observe(flow);
  }

  document.addEventListener('astro:page-load', initFlow);
  document.addEventListener('astro:before-swap', teardown);
</script>

<script>
  // process timeline: rows fade up once on scroll-in, then a glowing accent
  // "spark" rides the rail node → node (lighting each as it arrives), holds at
  // the end, resets, and loops while the section is on screen. Node y-positions
  // are measured from layout, so the loop is rebuilt on a debounced resize.
  // Skips entirely when motion is off (no-JS / reduced-motion) and rebinds
  // cleanly across View-Transition navigations.
  import { animate, stagger, createTimeline } from 'animejs';

  let entranceIo: IntersectionObserver | null = null;
  let playIo: IntersectionObserver | null = null;
  let tl: ReturnType<typeof createTimeline> | null = null;
  let spark: HTMLElement | null = null;
  let onResize: (() => void) | null = null;
  let resizeTimer = 0;

  function teardownProc() {
    entranceIo?.disconnect();
    entranceIo = null;
    playIo?.disconnect();
    playIo = null;
    tl?.pause();
    tl?.revert();
    tl = null;
    if (onResize) {
      window.removeEventListener('resize', onResize);
      onResize = null;
    }
    spark?.remove();
    spark = null;
    document
      .querySelectorAll<HTMLElement>('.proc-node.is-active')
      .forEach((n) => n.classList.remove('is-active'));
  }

  // (re)build the looping spark against the current layout — also what the
  // debounced resize handler calls, since node centres are pixel-based.
  function buildSpark(proc: HTMLElement, nodes: HTMLElement[]) {
    playIo?.disconnect();
    playIo = null;
    tl?.pause();
    tl?.revert();
    tl = null;
    spark?.remove();
    nodes.forEach((n) => n.classList.remove('is-active'));

    spark = document.createElement('span');
    spark.className = 'proc-spark';
    proc.appendChild(spark);

    const base = proc.getBoundingClientRect();
    const first = nodes[0].getBoundingClientRect();
    const x = first.left - base.left + first.width / 2;
    const ys = nodes.map((n) => {
      const r = n.getBoundingClientRect();
      return r.top - base.top + r.height / 2;
    });
    spark.style.left = `${x}px`;
    spark.style.top = `${ys[0]}px`;

    const STEP = 520; // travel time between adjacent nodes
    const DWELL = 150; // pause on each node
    const HOLD = 700; // pause at the end before the reset

    tl = createTimeline({ loop: true, autoplay: false, defaults: { ease: 'inOutQuad' } });

    // light the first node as the spark fades in
    tl.add(
      spark,
      { opacity: [0, 1], duration: 220, ease: 'outQuad', onBegin: () => nodes[0].classList.add('is-active') },
      0
    );
    let at = DWELL;
    for (let i = 0; i < nodes.length - 1; i++) {
      const next = nodes[i + 1];
      tl.add(spark, { top: [ys[i], ys[i + 1]], duration: STEP, onComplete: () => next.classList.add('is-active') }, at);
      at += STEP + DWELL;
    }
    // hold on the full rail, then snuff spark + nodes and drop back to the top
    tl.add(spark, { opacity: [1, 0], duration: 260, ease: 'outQuad' }, at + HOLD);
    tl.add(
      spark,
      { top: ys[0], duration: 1, onBegin: () => nodes.forEach((n) => n.classList.remove('is-active')) },
      at + HOLD + 260
    );

    playIo = new IntersectionObserver(
      (entries) => entries.forEach((e) => (e.isIntersecting ? tl?.play() : tl?.pause())),
      { threshold: 0.25 }
    );
    playIo.observe(proc);
  }

  function initProc() {
    teardownProc();

    if (!document.documentElement.classList.contains('motion')) return;

    const proc = document.querySelector<HTMLElement>('.proc');
    if (!proc) return;

    const steps = [...proc.querySelectorAll<HTMLElement>('.proc-step')];
    const nodes = [...proc.querySelectorAll<HTMLElement>('.proc-node')];
    if (!steps.length || !nodes.length) return;

    entranceIo = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          entranceIo?.unobserve(e.target);

          // rows fade up once; build the spark only after they settle, so node
          // y-positions are measured at rest (the rows translateY during this).
          animate(steps, {
            opacity: [0, 1],
            translateY: [12, 0],
            duration: 560,
            delay: stagger(90),
            ease: 'outCubic',
            onComplete: () => {
              steps.forEach((el) => (el.style.willChange = 'auto'));
              buildSpark(proc, nodes);
            },
          });
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -8% 0px' }
    );
    entranceIo.observe(proc);

    onResize = () => {
      if (!spark) return; // only after the first build
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => buildSpark(proc, nodes), 160);
    };
    window.addEventListener('resize', onResize);
  }

  document.addEventListener('astro:page-load', initProc);
  document.addEventListener('astro:before-swap', teardownProc);
</script>
