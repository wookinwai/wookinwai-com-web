---
import QRCode from 'qrcode';
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { SITE, PROFILE_LINKS } from '../consts';

const title = `${SITE.author} — Digital card`;
const description = `${SITE.author}, ${SITE.role}. Save my contact, scan the code, or reach me on any channel.`;

const cardUrl = `${SITE.url}/card`;

// Build-time QR generation — `qrcode` runs in Node during the build and the SVG
// is inlined, so nothing ships to the client. Recolor it to inherit the palette:
// foreground → currentColor (text-ink), background → transparent.
const rawQr = await QRCode.toString(cardUrl, { type: 'svg', margin: 0, errorCorrectionLevel: 'M' });
const qrSvg = rawQr
  .replace('#ffffff', 'transparent')
  .replace('#000000', 'currentColor')
  .replace('<svg ', '<svg class="h-full w-full" ');

// Reused row chrome — the signature hard-shouldered button that slams into
// signal red on hover (same idiom as EmailButton / the footer chip).
const rowBase =
  'group flex items-center gap-4 rounded-[2px] border-2 border-rule px-[18px] py-[15px] no-underline shadow-card transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:border-acc hover:bg-acc hover:text-on-accent hover:shadow-acc';
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-[520px] pb-10 pt-[64px] max-[760px]:pt-[44px]">
    <!-- 1 — Identity -->
    <header class="flex items-center gap-5 max-[420px]:flex-col max-[420px]:items-start max-[420px]:gap-4">
      <img
        src="/woo-kin-wai-software-builder.avif"
        width="104"
        height="104"
        alt={`Portrait of ${SITE.author}`}
        class="rise d1 h-[104px] w-[104px] flex-none rounded-[2px] border-2 border-rule object-cover shadow-card"
      />
      <div>
        <div class="rise d1 font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-acc">Digital card</div>
        <h1 class="rise d2 mt-[10px] font-sans text-[clamp(28px,7vw,40px)] font-extrabold leading-[1.02] tracking-[-0.035em] text-ink">
          {SITE.author}
        </h1>
        <p class="rise d2 mt-[8px] font-sans text-[15px] leading-[1.4] text-mut">{SITE.role}</p>
        <p class="rise d3 mt-[6px] font-mono text-[11px] uppercase tracking-[0.12em] text-soft">
          {SITE.location} · GMT+8
        </p>
      </div>
    </header>

    <!-- 2 — Primary actions -->
    <div class="rise d3 mt-9 flex flex-wrap gap-3">
      <a
        href="/woo-kin-wai.vcf"
        download
        class="inline-flex items-center gap-2 rounded-[2px] border-2 border-acc bg-acc px-[18px] py-3 font-sans text-[15px] font-extrabold tracking-[-0.01em] text-on-accent no-underline shadow-acc transition-all hover:-translate-x-0.5 hover:-translate-y-0.5"
      >
        <SocialIcon name="email" class="h-[15px] w-[15px]" /> Save contact
      </a>
      <button
        id="copy-email"
        type="button"
        data-email={SITE.email}
        data-label="Copy email"
        class="inline-flex items-center gap-2 rounded-[2px] border-2 border-rule bg-transparent px-[18px] py-3 font-sans text-[15px] font-extrabold tracking-[-0.01em] text-ink shadow-card transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:border-acc hover:bg-acc hover:text-on-accent hover:shadow-acc"
      >
        <span data-copy-label>Copy email</span>
      </button>
    </div>

    <!-- 3 — Channels -->
    <nav class="mt-9 flex flex-col gap-3" data-stagger aria-label="Contact channels">
      {
        PROFILE_LINKS.map((c) => (
          <a
            href={c.href}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener noreferrer' : undefined}
            class={rowBase}
          >
            <span class="flex-none text-mut transition-colors group-hover:text-on-accent">
              <SocialIcon name={c.icon} class="h-[18px] w-[18px]" />
            </span>
            <span class="min-w-0 flex-1">
              <span class="block font-sans text-[15px] font-extrabold leading-tight tracking-[-0.01em] text-ink transition-colors group-hover:text-on-accent">
                {c.label}
              </span>
              <span class="block truncate font-mono text-[12px] leading-tight text-soft transition-colors group-hover:text-on-accent">
                {c.value}
              </span>
            </span>
            <span class="flex-none font-mono text-[13px] text-soft transition-colors group-hover:text-on-accent">
              {c.external ? '↗' : '→'}
            </span>
          </a>
        ))
      }
    </nav>

    <!-- 4 — QR -->
    <div class="reveal mt-12 flex flex-col items-center border-t-2 border-rule pt-10">
      <div class="h-[150px] w-[150px] rounded-[2px] border-2 border-rule bg-panel p-3 text-ink shadow-card">
        <Fragment set:html={qrSvg} />
      </div>
      <p class="mt-4 font-mono text-[10.5px] font-bold uppercase tracking-[0.16em] text-soft">Scan to open · share</p>
    </div>
  </div>

  <script>
    // Copy-email affordance. Re-binds on every View-Transitions navigation
    // (astro:page-load), same pattern as the chrome handlers in BaseLayout.
    function initCardCopy() {
      const btn = document.getElementById('copy-email');
      if (!btn || btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      const label = btn.querySelector('[data-copy-label]') as HTMLElement | null;
      const email = btn.dataset.email || '';
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(email);
        } catch (e) {
          return;
        }
        if (!label) return;
        const original = btn.dataset.label || label.textContent || '';
        label.textContent = 'Copied ✓';
        window.setTimeout(() => {
          label.textContent = original;
        }, 1500);
      });
    }
    document.addEventListener('astro:page-load', initCardCopy);
  </script>
</BaseLayout>
