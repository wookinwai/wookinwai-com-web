---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const notes = (await getCollection('notes')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });

const page = 'mx-auto max-w-[1060px] px-7';
---

<BaseLayout title="Notes - Woo Kin Wai" description="Notes on software, systems, and building with founders and SMEs.">
  <header class:list={[page, 'pt-24']}>
    <h1 class="m-0 font-serif text-[clamp(36px,4.8vw,58px)] font-[380] leading-[1.14] tracking-[-0.01em]">
      Field <i class="italic text-ribbon">notes</i>
    </h1>
    <p class="mt-6 max-w-[56ch] text-[20px] text-soft">
      Notes on software, systems, and building with founders and SMEs.
    </p>
  </header>

  <div class:list={[page, 'mt-14']}>
    {
      notes.length === 0 ? (
        <p class="border-t border-hairline pt-8 font-serif italic text-faint">No notes yet.</p>
      ) : (
        notes.map((note, i) => (
          <article class:list={['spread border-t border-hairline py-8', i === notes.length - 1 && 'border-b']}>
            <aside class="margin-note">
              {fmt(note.data.pubDate)}
              {note.data.tags.length > 0 && (
                <>
                  <br />
                  <em>{note.data.tags.join(' · ')}</em>
                </>
              )}
            </aside>
            <div>
              <h2 class="m-0 font-serif text-[26px] font-[480] leading-[1.2] tracking-[-0.005em]">
                <a href={`/notes/${note.data.slug}`} class="no-underline hover:text-ribbon hover:underline">
                  {note.data.title}
                </a>
              </h2>
              <p class="mb-0 mt-2 max-w-[58ch] text-[17px] text-soft">{note.data.description}</p>
            </div>
          </article>
        ))
      )
    }
  </div>
</BaseLayout>
