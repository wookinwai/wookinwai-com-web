---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const notes = (await getCollection('notes')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  `${d.getUTCFullYear()} · ${String(d.getUTCMonth() + 1).padStart(2, '0')} · ${String(d.getUTCDate()).padStart(2, '0')}`;
---

<BaseLayout
  title="Notes - Woo Kin Wai"
  description="Notes on software, systems, and building with founders and SMEs."
>
  <header class="max-w-[880px] pt-[92px] max-[760px]:pt-16">
    <div class="mb-[30px] font-mono text-[12.5px] tracking-[0.04em] text-acc">notes /</div>
    <h1
      class="mb-[30px] font-sans text-[clamp(32px,5.4vw,58px)] font-semibold leading-[1.08] tracking-[-0.018em] text-ink"
    >
      Field <em class="font-medium italic text-acc">notes</em>
    </h1>
    <p class="max-w-[700px] text-[18.5px] leading-[1.6] text-mut">
      Notes on software, systems, and building with founders and SMEs.
    </p>
  </header>

  {
    notes.length === 0 ? (
      <p class="mt-14 font-mono text-[12.5px] text-soft">no notes yet.</p>
    ) : (
      <div class="mb-12 mt-14 border-t border-line" data-stagger>
        {notes.map((note) => (
          <a
            href={`/notes/${note.data.slug}`}
            class="row-edge group grid grid-cols-[150px_1fr] items-baseline gap-[18px] border-b border-line py-[22px] no-underline transition-colors hover:bg-panel max-[760px]:grid-cols-1 max-[760px]:gap-2"
          >
            <div class="whitespace-nowrap pt-1 font-mono text-[12px] text-soft">{fmt(note.data.pubDate)}</div>
            <div>
              <div class="text-[22px] font-semibold leading-[1.12] text-ink transition-colors group-hover:text-acc">
                {note.data.title}
              </div>
              <p class="mt-1.5 text-[14.5px] leading-[1.55] text-mut">{note.data.description}</p>
              {note.data.tags.length > 0 && (
                <div class="mt-2.5 flex flex-wrap gap-x-4 gap-y-1 font-mono text-[11px] text-soft">
                  {note.data.tags.map((tag) => (
                    <span>/ {tag.toLowerCase()}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
