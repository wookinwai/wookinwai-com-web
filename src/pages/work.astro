---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailButton from '../components/EmailButton.astro';
import ShotFrame from '../components/ShotFrame.astro';
import { pageGraph } from '../lib/seo';

const title = 'Work - Woo Kin Wai, Software Builder & Technical Partner';
const description =
  "Case notes on the systems I've shaped and built with founders and SMEs: the opportunity, the decisions, and what exists today.";

const graph = pageGraph({ url: Astro.url, title, description });

// Shared spacing — same scale as the homepage sections.
const secWrap = 'reveal pt-24 max-[760px]:pt-20';
// Case-study anchors are jumped to from the homepage cards and the index
// below, so they need to clear the sticky header (taller on mobile).
const anchorWrap = `${secWrap} scroll-mt-24 max-[760px]:scroll-mt-36`;

// Case notes are LOCAL editorial content, deliberately not CMS-driven: the
// homepage cards stay the CMS summary, this page carries the longer story.
// Status/model/role strings here must be kept in step with the CMS entries
// by hand. Ids match the CMS slugs so homepage cards can deep-link.
//
// Blocks marked [ASSUMPTION] are scaffolding drafted to show the shape and
// still need the real story. [PENDING] blocks are awaiting inputs.
interface Decision {
  lead: string;
  body: string;
}
interface Study {
  slug: string;
  name: string;
  tease: string;
  status: 'live' | 'building' | 'testing' | 'ongoing' | 'closed';
  statusLabel: string;
  relationship: string; // engagement model, e.g. 'stake or revenue-share partnership'
  roleLabel: string; // short role tag, e.g. 'technical partner'
  gap: string[];
  system: string[];
  decisions: Decision[];
  decisionsLabel?: string; // field label for the decisions block; defaults to 'decisions along the way'
  role: string;
  currentState: string;
  stack: string[]; // empty = row omitted
}

const studies: Study[] = [
  {
    slug: 'concrix',
    name: 'Concrix',
    tease: 'A marketplace for surplus construction materials.',
    status: 'building',
    statusLabel: 'in build',
    relationship: 'stake in the venture',
    roleLabel: 'technical partner',
    gap: [
      'Surplus construction materials hold real value, but much of the trade still happens through WhatsApp groups, Facebook posts, and personal networks. Supply and demand are scattered, making it difficult for sellers and buyers to find each other at the right time.',
      'The first version of Concrix was built on WooCommerce so we could test the idea quickly and learn from real use. It helped validate that the problem was worth pursuing, but we are still testing the business model, understanding buyer and seller behaviour, and working towards market fit.',
    ],
    system: [
      'A custom marketplace built around listing, discovery, matching, and the workflows that emerge as we continue validating the business.',
      'The aim is to move the trade from scattered informal demand towards a working product.',
    ],
    decisions: [
      // [NOTE] The validate-then-rebuild story is deliberately told here and
      // not on the homepage card. Cut these blocks to untell it everywhere.
      {
        lead: 'Use the first version to learn quickly.',
        body: 'The first version ran on WooCommerce so we could put the idea into the market without betting on a large custom build. It gave us something real to learn from and helped confirm that the problem was worth pursuing.',
      },
      {
        lead: 'Move to a custom platform to follow the business, not the store.',
        body: 'WooCommerce helped us test the first version quickly, but it also placed the product inside a conventional e-commerce structure. We are still testing the business model and working towards market fit. A custom build gives us more room to change the workflows, pivot the product, and shape the system around what the market teaches us.',
      },
    ],
    role: 'I am the technical partner from the start, with a stake in the venture. Because this is a partnership rather than a fee-based engagement, my role extends beyond the code into product direction, technical decisions, business-model validation, and the path towards market fit. I am now leading the custom platform build so we have more room to pivot and learn as the business evolves.',
    currentState:
      'In build. Moving from the first WooCommerce version into a custom platform, still testing the business model and working towards market fit.',
    // [PENDING] Current Concrix stack still owed (earlier change-list item #8);
    // row is omitted until it lands here and in the CMS.
    stack: [],
  },
  {
    slug: 'tixlah',
    name: 'Tixlah',
    tease: 'An e-ticketing platform built mainly for running and sports events.',
    status: 'testing',
    statusLabel: 'in testing',
    relationship: 'longer-term partnership with a share in the outcome',
    roleLabel: 'platform architect',
    gap: [
      'Running and sports events need a clear flow from registration and payment through to participant management and event-day entry.',
      'Organisers often rely on separate forms, payment tools, spreadsheets, and check-in lists. Each tool may work on its own, but together they create duplicated work, fragmented records, and more operational effort.',
    ],
    system: [
      'An e-ticketing platform built with EC Pixels Asia, bringing event listings, registration, payment, participant management, ticket confirmation, and QR-based event-day entry into one system.',
    ],
    decisions: [
      {
        lead: 'Built around running and sports events.',
        body: 'The platform was designed around the needs of running and sports events, rather than as a general-purpose ticketing website.',
      },
      {
        lead: 'Built for registration peaks and event-day operations.',
        body: 'The technical foundation had to support concentrated registration traffic, reliable ticket allocation, payment processing, and the operational workflows organisers need before and during an event.',
      },
    ],
    role: 'I lead the platform architecture and technical direction, working closely with EC Pixels Asia on the product and event requirements. The Tiny Edges team is involved in the implementation, turning the agreed direction into the working platform. This is a longer-term partnership with a share in the outcome.',
    currentState: 'In testing with real event flows ahead of official launch.',
    stack: ['astro', 'hono', 'cloudflare workers', 'postgresql'],
  },
  {
    slug: 'beyond-insights',
    name: 'Beyond Insights',
    tease: 'Student-facing web and mobile products for an investment and trading educator.',
    status: 'building',
    statusLabel: 'in build',
    relationship: 'fee-based engagement',
    roleLabel: 'build partner',
    decisionsLabel: 'technical choices',
    gap: [
      'Beyond Insights teaches thousands of students and already had a web student portal supporting their learning experience.',
      'Their team brought Tiny Edges in to build their first mobile apps for iOS and Android. We are now also working on the next version of the web student portal.',
      'The business and product direction are led by their team. They needed a build partner to turn those decisions into working software and advise on the technical approach where it affected delivery, maintainability, and future development.',
    ],
    system: [
      'Student-facing products across mobile and web: the first iOS and Android apps already shipped, with the next version of the web student portal now in build.',
    ],
    decisions: [
      {
        lead: 'Use React Native for the first mobile apps.',
        body: 'I recommended React Native so that the first iOS and Android apps could be developed through a shared codebase. This reduced duplicated implementation while still allowing platform-specific work where needed.',
      },
      {
        lead: 'Use Next.js for the new student portal.',
        body: 'I recommended Next.js because it is widely adopted, actively maintained, and supported by a mature ecosystem. That made it a practical foundation for a portal that would need to be maintained and extended over time.',
      },
    ],
    role: 'Build partner on a fee-based engagement. Their team leads the business and product decisions. I advise on the technical approach and architecture, and work alongside their internal team on delivery, while the Tiny Edges team handles implementation across the first mobile apps and the new web student portal.',
    currentState: 'First iOS and Android apps shipped. New web student portal in build.',
    stack: ['react native', 'nestjs', 'next.js'],
  },
];

// The Oryza retrospective keeps its own shape on purpose (no opportunity /
// gap / system fields): a closed venture, not a case study.
// [ASSUMPTION] The whole story block is scaffolding; "what I built" and
// "what the market did not validate" in particular need the real answers.
const oryza = {
  intro:
    'Before Tiny Edges, I started Oryza. It did not become a business. I keep it on the record because leaving out the work that failed would make the rest less honest.',
  rows: [
    [
      'what i believed',
      'That a well-architected product would find its market. I built for the system I wanted to exist, not the customer who would pay for it.',
    ],
    // [ASSUMPTION] One or two real sentences on what Oryza actually was.
    [
      'what i built',
      'My first attempt at a product company. The product worked, but the market had not asked for it.',
    ],
    // [ASSUMPTION] The specific thing that didn't work: no willingness to
    // pay, wrong timing, no distribution.
    [
      'what the market did not validate',
      'A business around the build. The product worked, but paying customers, timing, and distribution never lined up to carry it.',
    ],
    [
      'what i would do differently',
      'Start with the smallest version that could test the business model, not the architecture. Talk to the market before the code. Treat distribution as part of the build, not something that comes after.',
    ],
    [
      'how it changed the later work',
      'Architecture is not enough. Business model, timing, market, and distribution decide whether a product survives. Every engagement above starts from that lesson: understand where the business is trying to go before deciding what to build. It is also why Concrix started with a lean first version instead of a custom build.',
    ],
  ],
};

// Keep the editorial case notes local, but take their order from the same CMS
// sortOrder that drives the homepage. If the CMS is unavailable in dev, the
// source order above remains the fallback.
const cmsWork = await getCollection('work');
const cmsOrder = new Map(cmsWork.map((entry) => [entry.id, entry.data.sortOrder]));
const fallbackPosition = new Map(studies.map((study, i) => [study.slug, i]));
const sortOrderOf = (slug: string) => cmsOrder.get(slug) ?? Number.POSITIVE_INFINITY;
const orderedStudies = [...studies].sort((a, b) => {
  const orderDifference = sortOrderOf(a.slug) - sortOrderOf(b.slug);
  return orderDifference || (fallbackPosition.get(a.slug) ?? 0) - (fallbackPosition.get(b.slug) ?? 0);
});

// Index rows are a contents list, not a summary: number, name, status only.
// Tease, relationship, and role live in the case notes below, so the index
// never repeats them.
const indexRows = [
  ...orderedStudies.map((s) => ({
    href: `#${s.slug}`,
    name: s.name,
    status: s.status,
    statusLabel: s.statusLabel,
    sortOrder: sortOrderOf(s.slug),
  })),
  {
    href: '#oryza',
    name: 'Oryza Technologies',
    status: 'closed',
    statusLabel: 'closed',
    sortOrder: cmsOrder.get('oryza-technologies') ?? cmsOrder.get('oryza') ?? Number.POSITIVE_INFINITY,
  },
].sort((a, b) => a.sortOrder - b.sortOrder);
const index = indexRows.map(({ sortOrder: _sortOrder, ...row }) => row);

const fieldRow = 'grid grid-cols-[220px_1fr] gap-8 border-b border-line py-7 max-[700px]:grid-cols-1 max-[700px]:gap-3';
const fieldLabel = 'pt-[2px] font-mono text-anno text-soft max-[700px]:pt-0';

// Screenshots stay CMS-managed: join by slug so each case study shows the
// same shot (and frame) as its homepage card. No CMS entry, no figure —
// the page still builds standalone when the CMS is unreachable in dev.
const cmsShots = new Map(cmsWork.map((entry) => [entry.id, entry.data]));
---

<BaseLayout title={title} description={description} graph={graph} noindex={true}>
  <!-- Hero -->
  <header class="max-w-[880px] pt-[92px] max-[760px]:pt-16">
    <div class="rise d1 mb-[30px] kicker">work · what was built, and why it was shaped that way</div>
    <h1
      class="rise d2 mb-[30px] text-balance font-display text-[clamp(32px,5.4vw,58px)] font-extrabold leading-[1.08] tracking-[-0.018em] text-ink"
    >
      Work shaped around the <em class="em-acc">business</em>.
    </h1>
    <p class="rise d3 max-w-[700px] text-[18.5px] leading-[1.6] text-ink">
      These are notes on what each business needed, how the system was shaped, the decisions made along the way, and
      what exists today.
    </p>
    <p class="rise d3 mt-5 max-w-[700px] text-[16.5px] leading-[1.62] text-ink">
      I usually work in one of two ways: through a <b class="font-semibold">fee-based engagement</b>, or through a{' '}
      <b class="font-semibold">partnership built around a stake or revenue share</b>. Both are normal ways I work. The
      right model depends on the work, the relationship, and how closely our interests should be aligned.
    </p>
    <p class="rise d3 mt-4 max-w-[700px] text-[16.5px] leading-[1.62] text-ink">
      One project below was my own venture. It did not make it, and it stays on the record.
    </p>
  </header>

  <!-- Project index — a drafting-sheet contents list. Number, name, status
       only: the tease, relationship, and role belong to the case notes below. -->
  <section class="reveal pt-16 max-[760px]:pt-12">
    <div class="max-w-[520px]">
      <div class="border-b border-rule pb-2.5 font-mono text-anno text-soft">contents /</div>
      {
        index.map((row, i) => (
          <a
            href={row.href}
            class="row-edge group flex touch-manipulation items-baseline gap-x-5 border-b border-line py-[13px] no-underline transition-colors hover:bg-panel focus-visible:bg-panel active:bg-panel"
          >
            <span class="font-mono text-anno-sm text-soft">{String(i + 1).padStart(2, '0')}</span>
            <span class="min-w-0 text-[16.5px] font-semibold leading-[1.3] text-ink transition-colors group-hover:text-acc">
              {row.name}
            </span>
            <span class="ml-auto flex shrink-0 items-center gap-1.5 whitespace-nowrap font-mono text-anno-sm text-mut">
              <span class:list={['smark', row.status]} />
              {row.statusLabel}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Case studies -->
  {
    orderedStudies.map((s) => {
      const shot = cmsShots.get(s.slug);
      const hasShot = Boolean(shot && (shot.screenshotUrl || shot.shot));
      // Live-site link (CMS `visit`: { href, label }), shown as its own meta
      // item. Null for entries without a public URL, so the block is omitted.
      const visit = shot?.visit ?? null;
      return (
        <section class={anchorWrap} id={s.slug}>
          <header class="relative flex flex-wrap items-baseline gap-x-5 gap-y-2 pb-[22px]">
            <h2 class="m-0 font-display text-[clamp(26px,3.4vw,36px)] font-extrabold leading-[1.1] tracking-[-0.015em] text-ink">
              {s.name}
            </h2>
            <span class="text-[16px] italic text-mut">{s.tease}</span>
            <div class="sec-rule absolute inset-x-0 bottom-0 h-px bg-rule" />
          </header>
          <div class="mt-8 flex flex-wrap items-start gap-x-14 gap-y-7">
            {hasShot && shot && (
              <figure
                class:list={['m-0 min-w-0 flex-1', shot.shotFrame === 'mobile' ? 'max-w-[300px]' : 'max-w-[680px]']}
              >
                <ShotFrame
                  frame={shot.shotFrame}
                  src={shot.screenshotUrl}
                  alt={shot.screenshotAlt || shot.shot?.label || `${s.name} screenshot`}
                  pill={shot.shot?.url}
                  name={s.name}
                />
                {shot.shot?.label && (
                  <figcaption
                    class:list={[
                      'px-0.5 pt-3 font-mono text-anno-sm text-mut',
                      shot.shotFrame === 'mobile' && 'text-center',
                    ]}
                  >
                    {shot.shot.label}
                  </figcaption>
                )}
              </figure>
            )}
            {/* Status, relationship, and role are three separate facts, and
                the visit link is the one action; keep them visibly distinct
                instead of one run-together meta line. */}
            <div
              class:list={[
                'flex font-mono text-anno',
                hasShot ? 'w-[180px] shrink-0 flex-col gap-6 pt-1' : 'flex-wrap gap-x-14 gap-y-6',
              ]}
            >
              <div>
                <div class="text-anno-sm text-soft">status /</div>
                <div class="mt-1.5 flex items-center gap-1.5 whitespace-nowrap text-mut">
                  <span class:list={['smark', s.status]} />
                  {s.statusLabel}
                </div>
              </div>
              <div>
                <div class="text-anno-sm text-soft">relationship /</div>
                <div class="mt-1.5 text-acc">{s.relationship}</div>
              </div>
              <div>
                <div class="text-anno-sm text-soft">role /</div>
                <div class="mt-1.5 text-acc">{s.roleLabel}</div>
              </div>
              {visit && visit.href && (
                <div>
                  <div class="text-anno-sm text-soft">visit /</div>
                  <a
                    href={visit.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-1.5 inline-block border-b border-acc pb-0.5 text-acc no-underline transition-colors hover:border-acc-2 hover:text-acc-2"
                  >
                    {visit.label}
                  </a>
                </div>
              )}
            </div>
          </div>
          <div class="mt-8 max-w-[920px] border-t border-line" data-stagger>
            <div class={fieldRow}>
              <div class={fieldLabel}>the opportunity and the gap /</div>
              <div>
                {s.gap.map((p) => (
                  <p class="mb-4 mt-0 max-w-[680px] text-[16.5px] leading-[1.62] text-ink last:mb-0">{p}</p>
                ))}
              </div>
            </div>
            <div class={fieldRow}>
              <div class={fieldLabel}>the system /</div>
              <div>
                {s.system.map((p) => (
                  <p class="mb-4 mt-0 max-w-[680px] text-[16.5px] leading-[1.62] text-ink last:mb-0">{p}</p>
                ))}
              </div>
            </div>
            <div class={fieldRow}>
              <div class={fieldLabel}>{s.decisionsLabel ?? 'decisions along the way'} /</div>
              <div class="space-y-6">
                {s.decisions.map((d) => (
                  <div class="max-w-[680px]">
                    <p class="m-0 text-[16.5px] font-semibold leading-[1.45] text-ink">{d.lead}</p>
                    <p class="mb-0 mt-1.5 text-[15.5px] leading-[1.62] text-mut">{d.body}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class={fieldRow}>
              <div class={fieldLabel}>my role /</div>
              <p class="m-0 max-w-[680px] text-[16.5px] leading-[1.62] text-ink">{s.role}</p>
            </div>
            <div class={fieldRow}>
              <div class={fieldLabel}>current state /</div>
              <p class="m-0 max-w-[680px] text-[16.5px] leading-[1.62] text-ink">{s.currentState}</p>
            </div>
            {s.stack.length > 0 && (
              <div class={fieldRow}>
                <div class={fieldLabel}>technical foundation /</div>
                <div class="font-mono text-anno-md text-mut">{s.stack.join(' · ')}</div>
              </div>
            )}
          </div>
        </section>
      );
    })
  }

  <!-- Oryza retrospective — a closed venture, kept in a visibly different shape -->
  <section class={anchorWrap} id="oryza">
    <div
      class="relative max-w-[920px] border border-dashed border-mut bg-bg px-12 py-11 max-[760px]:px-7 max-[760px]:py-8"
    >
      <div class="mb-6 flex items-center gap-3.5 font-mono text-anno text-mut">
        <span class="flex items-center gap-1.5 whitespace-nowrap">
          <span class="smark closed"></span>
          closed
        </span>
        <span class="text-soft" aria-hidden="true">·</span>
        <span>retrospective</span>
      </div>
      <h2
        class="m-0 max-w-[760px] text-balance font-display text-[clamp(26px,3.4vw,36px)] font-extrabold leading-[1.15] tracking-[-0.015em] text-ink"
      >
        Oryza Technologies: the venture that changed <em class="em-acc">how I build</em>.
      </h2>
      <p class="mb-0 mt-5 max-w-[680px] text-[17px] leading-[1.62] text-ink">{oryza.intro}</p>
      <div class="mt-8 border-t border-line" data-stagger>
        {
          oryza.rows.map(([label, text]) => (
            <div class="grid grid-cols-[220px_1fr] gap-8 border-b border-line py-6 max-[700px]:grid-cols-1 max-[700px]:gap-2">
              <div class="pt-[2px] font-mono text-anno text-soft max-[700px]:pt-0">{label} /</div>
              <p class="m-0 max-w-[640px] text-[15.5px] leading-[1.62] text-ink">{text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="reveal pb-12 pt-24 max-[760px]:pt-[72px]">
    <p
      class="m-0 max-w-[720px] text-balance font-display text-[clamp(26px,3.6vw,40px)] font-extrabold leading-[1.25] tracking-[-0.01em] text-ink"
    >
      Building something that doesn't fit neatly into a <em class="em-acc">standard brief?</em>
    </p>
    <p class="mb-0 mt-5 max-w-[640px] text-[18px] leading-[1.6] text-ink">
      Tell me where the business is trying to go, what is getting in the way, and what you have already tried.
    </p>
    <div class="mt-7 flex flex-wrap items-center gap-x-8 gap-y-4">
      <EmailButton />
      <a href="/contact/" class="group inline-flex items-baseline gap-2 font-mono text-anno-md no-underline">
        <span
          class="border-b border-acc pb-0.5 text-acc transition-colors group-hover:border-acc-2 group-hover:text-acc-2"
          >what to expect</span
        >
        <span class="text-acc transition-transform group-hover:translate-x-1 group-hover:text-acc-2" aria-hidden="true"
          >→</span
        >
      </a>
    </div>
  </section>
</BaseLayout>
